  "query": "SELECT c.id, c.teamMemberId, c.status, c.classification, tm.name as teamMemberName, \n       cg.overallScore\nFROM calls c\nJOIN team_members tm ON c.teamMemberId = tm.id\nLEFT JOIN call_grades cg ON c.id = cg.callId\nWHERE c.status = 'completed' \n  AND c.classification = 'conversation'\n  AND DATE(c.createdAt) >= DATE_SUB(CURDATE(), INTERVAL 1 DAY)\nORDER BY c.createdAt DESC\nLIMIT 50;",
