  // Multi-row arrays stored as dedicated JSON columns
  deedHistoryJson          Json? @map("deed_history_json")
  mortgageHistoryJson      Json? @map("mortgage_history_json")
  liensJson                Json? @map("liens_json")
  foreclosureDetailJson    Json? @map("foreclosure_detail_json")
  ownerPortfolioJson       Json? @map("owner_portfolio_json")
  valuationJson            Json? @map("valuation_json")
