// ─────────────────────────────────────────
// WORKFLOW ENGINE — sequences built in Gunner, executed via GHL
// ─────────────────────────────────────────

model WorkflowDefinition {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name         String
  triggerEvent String  @map("trigger_event") // property_created, stage_changed, call_graded, task_completed
  steps        Json    // [{type, delay?, action, content?, condition?}]
  isActive     Boolean @default(true) @map("is_active")

  executions WorkflowExecution[]

  @@map("workflow_definitions")
}

model WorkflowExecution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  workflowId String              @map("workflow_id")
  workflow   WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  contactId   String  @map("contact_id") // GHL contact ID
  propertyId  String? @map("property_id")
  currentStep Int     @default(0) @map("current_step")
  status      String  @default("active") // active, completed, paused, failed
  context     Json    @default("{}") // execution context: {callId, propertyId, score, etc.}
  nextRunAt   DateTime? @map("next_run_at") // when to run the next step (for delays)

  @@map("workflow_executions")
}

// ─────────────────────────────────────────
// BUYERS — disposition buyer list
// ─────────────────────────────────────────

model Buyer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── Identity & Contact ──────────────────
  // Legacy GHL-overlap identity columns — drop in v1.1 Wave 5 cutover.
  // Render path post-cutover: live-fetch from GHL via ghlContactId, with
  // skipTraced* below as fallback when ghlContactId is null.
  name                   String
  phone                  String?
  secondaryPhone         String?  @map("secondary_phone")
  mobilePhone            String?  @map("mobile_phone")
  email                  String?
  secondaryEmail         String?  @map("secondary_email")
  company                String?
  mailingAddress         String?  @map("mailing_address")
  mailingCity            String?  @map("mailing_city")
  mailingState           String?  @map("mailing_state")
  mailingZip             String?  @map("mailing_zip")
  website                String?
  // Q1/Shape A lock (v1.1 Wave 1) — skip-trace fallback identity. Used when
  // ghlContactId is null (rare for buyers — most arrive with a GHL contact).
  skipTracedName            String?  @map("skip_traced_name")
  skipTracedPhone           String?  @map("skip_traced_phone")
  skipTracedEmail           String?  @map("skip_traced_email")
  skipTracedCompany         String?  @map("skip_traced_company")
  skipTracedMailingAddress  String?  @map("skip_traced_mailing_address")
  preferredContactMethod String?  @map("preferred_contact_method") // call | text | email
  bestTimeToContact      String?  @map("best_time_to_contact")
  doNotContact           Boolean  @default(false) @map("do_not_contact")
  isDeceased             Boolean  @default(false) @map("is_deceased")
  isActive               Boolean  @default(true) @map("is_active")

  // ── GHL ─────────────────────────────────
  ghlContactId String? @map("ghl_contact_id")

  // ── Buybox — Geographic ─────────────────
  primaryMarkets          Json    @default("[]") @map("primary_markets")
  countiesOfInterest      Json    @default("[]") @map("counties_of_interest")
  citiesOfInterest        Json    @default("[]") @map("cities_of_interest")
  zipCodesOfInterest      Json    @default("[]") @map("zip_codes_of_interest")
  neighborhoodsOfInterest Json    @default("[]") @map("neighborhoods_of_interest")
  geographicExclusions    Json    @default("[]") @map("geographic_exclusions")
  maxDriveDistanceMiles   Int?    @map("max_drive_distance_miles")
  urbanRuralPreference    String? @map("urban_rural_preference") // urban | suburban | rural | any
  isNationalBuyer         Boolean @default(false) @map("is_national_buyer")
  isOutOfStateBuyer       Boolean @default(false) @map("is_out_of_state_buyer")

  // ── Buybox — Property ───────────────────
  propertyTypes       Json    @default("[]") @map("property_types") // SFR | MFR | commercial | land | mobile
