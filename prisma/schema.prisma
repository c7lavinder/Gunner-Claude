  spouseName           String?  @map("spouse_name")
  keyStaffNames        Json     @default("[]") @map("key_staff_names")
  lastInPersonMeeting  DateTime? @map("last_in_person_meeting")
  isVip                Boolean  @default(false) @map("is_vip")
  hasExclusivityAgreement Boolean @default(false) @map("has_exclusivity_agreement")

  // ── Strategy & Preferences ──────────────
  exitStrategies             Json    @default("[]") @map("exit_strategies")
  holdPeriodMonths           Int?    @map("hold_period_months")
  targetTenantProfile        String? @db.Text @map("target_tenant_profile")
  propertyManagementCompany  String? @map("property_management_company")
  typicalRehabTimelineDays   Int?    @map("typical_rehab_timeline_days")
  offMarketOnly              Boolean @default(false) @map("off_market_only")
  is1031Active               Boolean @default(false) @map("is_1031_active")
  isOpportunityZoneInterest  Boolean @default(false) @map("is_opportunity_zone_interest")
  creativeFinanceInterest    Boolean @default(false) @map("creative_finance_interest")
  isSubjectToBuyer           Boolean @default(false) @map("is_subject_to_buyer")

  // ── AI Enriched ─────────────────────────
  buyerScore             Float?   @map("buyer_score")
  matchLikelihoodScore   Float?   @map("match_likelihood_score")
  reliabilityPrediction  Float?   @map("reliability_prediction")
  communicationStyleAi   String?  @map("communication_style_ai")
  negotiationStyle       String?  @map("negotiation_style")
  ghostRiskScore         Float?   @map("ghost_risk_score")
  upsellPotential        Float?   @map("upsell_potential")
  lifetimeValueEstimate  Decimal? @db.Decimal(12, 2) @map("lifetime_value_estimate")
  aiSummary              String?  @db.Text @map("ai_summary")
  recommendedApproach    String?  @db.Text @map("recommended_approach")
  redFlagsAi             Json     @default("[]") @map("red_flags_ai")
  churnRisk              Float?   @map("churn_risk")
  lastAiAnalysisDate     DateTime? @map("last_ai_analysis_date")

  // ── General ──────────────────────────────
  tags          Json    @default("[]")
  internalNotes String? @db.Text @map("internal_notes")
  priorityFlag  Boolean @default(false) @map("priority_flag")
  customFields  Json    @default("{}") @map("custom_fields")
  fieldSources  Json    @default("{}") @map("field_sources")

  // ── Relations ────────────────────────────
  blastRecipients DealBlastRecipient[]
  propertyStages  PropertyBuyerStage[]
  calls           Call[]

  @@index([tenantId, phone])
  @@map("buyers")
}

// ─────────────────────────────────────────
// PROPERTY BUYER STAGES — Kanban pipeline per property
// ─────────────────────────────────────────

model PropertyBuyerStage {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  propertyId String   @map("property_id")
  buyerId    String   @map("buyer_id")
  stage      String   @default("matched") // matched | added | responded | interested
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Response tracking (Fix 6B)
  ghlResponse         String?   @map("ghl_response") @db.Text
  responseIntent      String?   @map("response_intent") // interested | not_interested | needs_followup | unclear
  responseAt          DateTime? @map("response_at")
  movedToRespondedAt  DateTime? @map("moved_to_responded_at")
  movedToInterestedAt DateTime? @map("moved_to_interested_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([propertyId, buyerId])
  @@map("property_buyer_stages")
}

// ─────────────────────────────────────────
// DEAL BLASTS — property marketing to buyers
// ─────────────────────────────────────────

model DealBlast {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id])

  createdById String @map("created_by_id")
  createdBy   User   @relation("BlastCreatedBy", fields: [createdById], references: [id])

  channel    String  // sms, email
  message    String  @db.Text
  status     String  @default("pending") // pending, approved, sent, failed
  approvedAt DateTime? @map("approved_at")
  sentAt     DateTime? @map("sent_at")

  recipients DealBlastRecipient[]

  @@map("deal_blasts")
}

model DealBlastRecipient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  blastId String    @map("blast_id")
  blast   DealBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)

  buyerId String @map("buyer_id")
  buyer   Buyer  @relation(fields: [buyerId], references: [id])

  response   String?   // interested, pass, no_response
  respondedAt DateTime? @map("responded_at")

  @@unique([blastId, buyerId])
  @@map("deal_blast_recipients")
}

// ─────────────────────────────────────────
// MARKETS — zip code to market mapping
// ─────────────────────────────────────────

model Market {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String           // e.g. "Nashville, TN"
  zipCodes String[] @default([]) @map("zip_codes") // ["37201", "37202", ...]

  properties Property[]

  @@map("markets")
}

// ─────────────────────────────────────────
// OUTREACH LOGS — sends, offers, showings
// ─────────────────────────────────────────

model OutreachLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation("OutreachLogUser", fields: [userId], references: [id])

  type             String   // send, offer, showing
  channel          String   // sms, email, call, in_person
  recipientName    String   @map("recipient_name")
  recipientContact String   @map("recipient_contact")
  ghlContactId     String?  @map("ghl_contact_id")
  notes            String?  @db.Text
  offerAmount      Float?   @map("offer_amount")
  offerStatus      String?  @map("offer_status")    // Pending, Accepted, Rejected, Countered, Expired
  showingDate      DateTime? @map("showing_date")
  showingStatus    String?  @map("showing_status")   // Scheduled, Completed, Cancelled, No Show
  source           String   @default("Manual") @map("source") // Manual, Blast, Auto
  loggedAt         DateTime @default(now()) @map("logged_at")

  @@map("outreach_logs")
}

// ─────────────────────────────────────────
// KNOWLEDGE DOCUMENTS — scripts, playbooks, standards, training
// Searchable by assistant via pgvector embeddings
// ─────────────────────────────────────────

model KnowledgeDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title    String                // "Cold Call Script v3"
  type     String                // script | standard | playbook | training | market | objection | industry
  callType String? @map("call_type") // cold_call | qualification_call | offer_call | etc
  role     String?               // LEAD_MANAGER | ACQUISITION_MANAGER | ALL | etc
  content  String  @db.Text      // full markdown content
  source   String  @default("upload") // upload | playbook | system
  isActive Boolean @default(true) @map("is_active")
  embedding Unsupported("vector")?

  @@index([embedding], map: "idx_knowledge_embedding_hnsw")
  @@map("knowledge_documents")
}

// ─────────────────────────────────────────
// USER PROFILES — auto-generated performance analysis
// Updated weekly from call grading history
// ─────────────────────────────────────────

model UserProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scoringPatterns     Json @default("{}") @map("scoring_patterns")      // avg per rubric category
  strengths           Json @default("[]") @map("strengths")             // string array
  weaknesses          Json @default("[]") @map("weaknesses")            // string array
  commonMistakes      Json @default("[]") @map("common_mistakes")       // string array
  communicationStyle  String? @map("communication_style")               // warm/direct/analytical/etc
  improvementVelocity Json @default("{}") @map("improvement_velocity")  // 30/60/90 day trends
  preferredActions    Json @default("{}") @map("preferred_actions")     // action type approval rates
  coachingPriorities  Json @default("[]") @map("coaching_priorities")   // ranked focus areas
  totalCallsGraded    Int @default(0) @map("total_calls_graded")
  profileSource       String @default("auto") @map("profile_source")   // auto | playbook | manual

  @@unique([tenantId, userId])
  @@map("user_profiles")
}

// ─────────────────────────────────────────
// ASSISTANT MESSAGES — daily persistent conversations
// ─────────────────────────────────────────

model AssistantMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId      String   @map("user_id")
  user        User     @relation("AssistantMessages", fields: [userId], references: [id], onDelete: Cascade)

  sessionDate String   @map("session_date") // YYYY-MM-DD — conversations persist within a day
  role        String                         // user | assistant | tool_call | tool_result
  content     String   @db.Text             // message text
  toolCalls   Json?    @map("tool_calls")   // actions proposed/executed
  pageContext String?  @map("page_context") // property:abc123 | call:xyz | dayhub | etc

  @@index([tenantId, userId, sessionDate])
  @@map("assistant_messages")
}

// ─────────────────────────────────────────
// ACTION LOG — tracks every AI action proposal + user decision
// ─────────────────────────────────────────

model ActionLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId    String @map("tenant_id")
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId      String @map("user_id")
  user        User   @relation("ActionLogs", fields: [userId], references: [id], onDelete: Cascade)

  actionType  String  @map("action_type")  // send_sms | create_task | change_stage | etc
  proposed    Json                          // what AI suggested
  executed    Json?                         // what was actually executed (after edits)
  wasEdited   Boolean @default(false) @map("was_edited")
  wasRejected Boolean @default(false) @map("was_rejected")
  editDiff    Json?   @map("edit_diff")    // what fields changed
  pageContext String? @map("page_context")

  @@map("action_logs")
}

// ─────────────────────────────────────────
// AI LOG — every AI call for admin debugging
// ─────────────────────────────────────────

model AiLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId     String  @map("tenant_id")
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId       String? @map("user_id") // null for system (auto-grading)
  type         String                   // assistant_chat | call_grading | deal_intel | next_steps | blast_gen | buyer_scoring | property_enrich | action_execution
  pageContext  String? @map("page_context")
  inputSummary String  @map("input_summary") @db.Text  // first 500 chars
  inputFull    String? @map("input_full") @db.Text      // full prompt (large)
  outputSummary String @map("output_summary") @db.Text  // first 500 chars
  outputFull   String? @map("output_full") @db.Text     // full response (large)
  toolsCalled  Json?   @map("tools_called")             // array of tool names + params
  status       String  @default("success")              // success | error | rejected | edited
  errorMessage String? @map("error_message") @db.Text
  tokensIn     Int?    @map("tokens_in")
  tokensOut    Int?    @map("tokens_out")
  estimatedCost Float? @map("estimated_cost")
  durationMs   Int?    @map("duration_ms")
  model        String?                                   // claude-sonnet-4-6, etc

  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@map("ai_logs")
}

// ─────────────────────────────────────────
// WEBHOOK LOG
// Every GHL webhook logged here immediately on arrival.
// Used for deduplication, debugging, and audit.
// ─────────────────────────────────────────
model WebhookLog {
  id          String   @id @default(cuid())
  receivedAt  DateTime @default(now()) @map("received_at")
  eventType   String   @map("event_type")
  messageId   String?  @map("message_id")
  locationId  String   @map("location_id")
  rawPayload  Json     @map("raw_payload")
  processed   Boolean  @default(false)
  callId      String?  @map("call_id")
  notes       String?

  // Source detection — how the webhook arrived
  webhookSource String? @map("webhook_source") // 'oauth' | 'automation'

  // Outcome tracking — written after processing completes or fails
  status      String   @default("received") // received | processing | success | failed
  processedAt DateTime? @map("processed_at")
  errorReason String?  @map("error_reason")

  tenantId    String?  @map("tenant_id")
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([locationId, receivedAt])
  @@index([tenantId, eventType])
  @@index([tenantId, status])
  @@index([tenantId, receivedAt])
  @@map("webhook_logs")
}

// ─────────────────────────────────────────
// CONTACT SUGGESTIONS
// AI-extracted field updates queued for rep review
// Push = accept as-is | Edit = modify then save | Skip = dismiss
// ─────────────────────────────────────────

model ContactSuggestion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Source
  callId     String? @map("call_id")
  propertyId String? @map("property_id")

  // Target
  targetType String  @map("target_type") // "seller" | "buyer" | "property"
  sellerId   String? @map("seller_id")
  buyerId    String? @map("buyer_id")

  // Suggestion content
  fieldName     String  @map("field_name")
  fieldLabel    String  @map("field_label")
  currentValue  Json?   @map("current_value")
  proposedValue Json    @map("proposed_value")
  confidence    Float?
  evidence      String? @db.Text

  // Decision
  status      String    @default("pending") // pending | approved | edited | skipped
  finalValue  Json?     @map("final_value")
  decidedAt   DateTime? @map("decided_at")
  decidedById String?   @map("decided_by_id")

  @@index([tenantId, propertyId, status])
  @@index([tenantId, sellerId, status])
  @@index([tenantId, buyerId, status])
  @@map("contact_suggestions")
}
