// Gunner AI — Prisma Schema
// Source of truth for all database models
// Run: npx prisma migrate dev --name <description>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// TENANTS
// Each paying client is a tenant. Fully isolated.
// ─────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Identity
  name    String
  slug    String  @unique // used in URL: gunnerai.com/{slug}/dashboard
  logoUrl String? @map("logo_url")

  // GHL OAuth (Marketplace App)
  ghlLocationId    String? @unique @map("ghl_location_id")   // sub-account ID
  ghlAccessToken   String? @map("ghl_access_token")
  ghlRefreshToken  String? @map("ghl_refresh_token")
  ghlTokenExpiry   DateTime? @map("ghl_token_expiry")
  ghlWebhookId     String? @map("ghl_webhook_id")

  // Call export cursor — tracks last processed message for reliable call ingestion
  lastCallExportCursor String? @map("last_call_export_cursor")

  // AI Knowledge — company-specific context for grading/coaching
  scripts          Json    @default("{}") @map("scripts")           // keyed by call type: {cold_call: "...", ...}
  companyStandards String? @map("company_standards") @db.Text       // company rules/standards
  calibrationCalls Json    @default("[]") @map("calibration_calls") // [{callId, type: "good"|"bad", notes}]

  // Property trigger config
  propertyPipelineId    String? @map("property_pipeline_id")    // which GHL pipeline (acquisition)
  propertyTriggerStage  String? @map("property_trigger_stage")  // which stage creates a property
  dispoPipelineId       String? @map("dispo_pipeline_id")       // GHL dispo pipeline
  dispoTriggerStage     String? @map("dispo_trigger_stage")     // stage that moves property into dispo

  // Onboarding state
  onboardingStep      Int     @default(0) @map("onboarding_step")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")

  // Stripe subscription
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripePriceId         String?   @map("stripe_price_id")
  subscriptionStatus    String?   @map("subscription_status")   // active, past_due, canceled, trialing
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")

  // Tenant-level config (JSON — flexible per client)
  callTypes    Json @default("[]") @map("call_types")    // ["inbound", "outbound", "followup"]
  callResults  Json @default("[]") @map("call_results")  // ["interested", "not interested", "callback"]
  config       Json @default("{}") // misc config blob

  // Tenant-specific grading materials (scripts, processes, company standards)
  // WRITES TO: tenants.grading_materials (String?)
  // API ENDPOINT: PATCH /api/tenants/config
  // READ BY: lib/ai/grading.ts → buildGradingSystemPrompt()
  gradingMaterials String? @map("grading_materials") @db.Text

  // Relations
  users         User[]
  properties    Property[]
  sellers       Seller[]
  calls         Call[]
  tasks         Task[]
  kpiSnapshots  KpiSnapshot[]
  auditLogs     AuditLog[]
  callRubrics   CallRubric[]
  roleConfigs   RoleConfig[]
  userXp              UserXp[]
  userBadges          UserBadge[]
  xpEvents            XpEvent[]
  leadSourceCosts     LeadSourceCost[]
  coachLogs           CoachLog[]
  workflowDefinitions WorkflowDefinition[]
  workflowExecutions  WorkflowExecution[]
  buyers              Buyer[]
  markets             Market[]
  outreachLogs        OutreachLog[]
  dealBlasts          DealBlast[]
  milestones          PropertyMilestone[]
  propertyBuyerStages PropertyBuyerStage[]
  propertyTeamMembers PropertyTeamMember[]
  knowledgeDocuments  KnowledgeDocument[]
  userProfiles        UserProfile[]
  assistantMessages   AssistantMessage[]
  actionLogs          ActionLog[]
  aiLogs              AiLog[]
  recordingFetchJobs  RecordingFetchJob[]
  webhookLogs         WebhookLog[]
  contactSuggestions  ContactSuggestion[]

  @@map("tenants")
}

// ─────────────────────────────────────────
// USERS
// Team members within a tenant
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Auth
  email          String  @unique
  hashedPassword String? @map("hashed_password")
  emailVerified  DateTime? @map("email_verified")

  // Profile
  name      String
  avatarUrl String? @map("avatar_url")
  phone     String?

  // Role + hierarchy
  role      UserRole
  reportsTo String? @map("reports_to") // user id of their manager

  // Manager relation (self-referential)
  manager    User?  @relation("UserReportsTo", fields: [reportsTo], references: [id])
  directReports User[] @relation("UserReportsTo")

  // Per-user config
  kpiConfig       Json @default("{}") @map("kpi_config")       // which KPIs to show
  cardConfig      Json @default("{}") @map("card_config")       // property card layout
  taskSortConfig  Json @default("{}") @map("task_sort_config")  // task list preferences
  dashboardConfig Json @default("{}") @map("dashboard_config")

  // GHL
  ghlUserId String? @map("ghl_user_id")

  // Relations
  assignedCalls      Call[]     @relation("CallAssignedTo")
  assignedTasks      Task[]     @relation("TaskAssignedTo")
  assignedProperties Property[] @relation("PropertyAssignedTo")
  kpiSnapshots       KpiSnapshot[]
  auditLogs          AuditLog[]
  xp                 UserXp?
  badges             UserBadge[]
  xpEvents           XpEvent[]
  coachLogs          CoachLog[]
  dealBlasts         DealBlast[] @relation("BlastCreatedBy")
  loggedMilestones   PropertyMilestone[] @relation("MilestoneLoggedBy")
  outreachLogs       OutreachLog[] @relation("OutreachLogUser")
  propertyTeamMembers PropertyTeamMember[] @relation("PropertyTeamMembers")
  userProfile         UserProfile?
  assistantMessages   AssistantMessage[] @relation("AssistantMessages")
  actionLogs          ActionLog[] @relation("ActionLogs")

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  TEAM_LEAD
  LEAD_MANAGER
  ACQUISITION_MANAGER
  DISPOSITION_MANAGER

  @@map("user_role")
}

// ─────────────────────────────────────────
// PROPERTIES (Inventory)
// Core of the wholesaling business
// NOT contacts — one seller can have multiple properties
// ─────────────────────────────────────────

model Property {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Assignment
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("PropertyAssignedTo", fields: [assignedToId], references: [id])

  // Address
  address String
  city    String
  state   String
  zip     String

  // Financial
  arv          Decimal? @db.Decimal(12, 2) // After Repair Value
  askingPrice  Decimal? @db.Decimal(12, 2) @map("asking_price")
  mao          Decimal? @db.Decimal(12, 2) // Max Allowable Offer
  contractPrice Decimal? @db.Decimal(12, 2) @map("contract_price")
  assignmentFee Decimal? @db.Decimal(12, 2) @map("assignment_fee")

  // Status — acquisition pipeline position (never overwritten by dispo)
  status PropertyStatus @default(NEW_LEAD)
  // Disposition pipeline position — null means not in dispo yet
  dispoStatus PropertyStatus? @map("dispo_status")

  // Lead tracking
  leadSource       String? @map("lead_source") // GHL opportunity source — tracked for KPIs
  leadSubSource    String? @map("lead_sub_source") // Sub-channel: "Google Ads", "Facebook", "PropertyLeads", etc.

  // TCP — True Conversion Probability (0.0 to 1.0)
  tcpScore     Float?    @map("tcp_score")
  tcpFactors   Json?     @map("tcp_factors") // {callSentiment, touchCount, equity, motivation, ...}
  tcpUpdatedAt DateTime? @map("tcp_updated_at")

  // GHL sync
  ghlContactId     String? @map("ghl_contact_id")
  ghlPipelineId    String? @map("ghl_pipeline_id")
  ghlPipelineStage String? @map("ghl_pipeline_stage")

  // Property details
  beds         Int?
  baths        Int?
  sqft         Int?
  yearBuilt    Int?     @map("year_built")
  lotSize      String?  @map("lot_size")
  propertyType String?  @map("property_type")  // House, Land, Multi-Family, Commercial, Other
  occupancy    String?                          // Vacant, Owner Occupied, Tenant Occupied, Unknown
  projectType  Json     @default("[]") @map("project_type") // ["Flip", "Rental", "Wholesale", etc.]
  lockboxCode  String?  @map("lockbox_code")
  description  String?  @db.Text
  internalNotes String? @db.Text @map("internal_notes")

  // Deal intel (gathered from calls)
  propertyCondition     String?  @map("property_condition")     // Move-in, minor repairs, major rehab, teardown
  competingOfferCount   Int?     @map("competing_offer_count")
  dealHealthScore       Int?     @map("deal_health_score")      // 1-10 composite from AI
  // Full deal intelligence JSON — accumulated from all calls
  dealIntel             Json?    @map("deal_intel") // See lib/types/deal-intel.ts for structure

  // Extended financials
  offerPrice     Decimal? @db.Decimal(12, 2) @map("offer_price")
  repairCost     Decimal? @db.Decimal(12, 2) @map("repair_cost")
  wholesalePrice Decimal? @db.Decimal(12, 2) @map("wholesale_price")
  currentOffer   Decimal? @db.Decimal(12, 2) @map("current_offer")
  highestOffer   Decimal? @db.Decimal(12, 2) @map("highest_offer")
  acceptedPrice  Decimal? @db.Decimal(12, 2) @map("accepted_price")
  finalProfit    Decimal? @db.Decimal(12, 2) @map("final_profit")

  // Source tracking for AI vs user edits — { fieldName: "ai" | "user" }
  fieldSources   Json     @default("{}") @map("field_sources")

  // Tracking dates
  lastOfferDate      DateTime? @map("last_offer_date")
  lastContactedDate  DateTime? @map("last_contacted_date")

  // Market assignment
  marketId String? @map("market_id")
  market   Market? @relation(fields: [marketId], references: [id])
  propertyMarkets  Json @default("[]") @map("property_markets") // ["Nashville", "Hot Springs", "Arkansas"]
  manualBuyerIds   Json @default("[]") @map("manual_buyer_ids") // GHL contact IDs added manually for this property

  // Enrichment (Phase 2 — Zillow, county records)
  zillowData   Json? @map("zillow_data")
  countyData   Json? @map("county_data")
  constructionEstimate Decimal? @db.Decimal(12, 2) @map("construction_estimate")

  // Utilities
  waterType       String? @map("water_type")
  waterNotes      String? @map("water_notes")
  sewerType       String? @map("sewer_type")
  sewerCondition  String? @map("sewer_condition")
  sewerNotes      String? @map("sewer_notes")
  electricType    String? @map("electric_type")
  electricNotes   String? @map("electric_notes")

  // AI enrichment (Fix 4)
  repairEstimate      Decimal? @db.Decimal(12, 2) @map("repair_estimate")
  rentalEstimate      Decimal? @db.Decimal(12, 2) @map("rental_estimate")
  neighborhoodSummary String?  @map("neighborhood_summary") @db.Text
  zestimate           Decimal? @db.Decimal(12, 2)
  deedDate            DateTime? @map("deed_date")
  taxAssessment       Decimal? @db.Decimal(12, 2) @map("tax_assessment")
  annualTax           Decimal? @db.Decimal(12, 2) @map("annual_tax")
  floodZone           String?  @map("flood_zone")
  aiEnrichmentStatus  String?  @map("ai_enrichment_status") // 'pending' | 'complete' | 'failed'
  aiEnrichmentError   String?  @map("ai_enrichment_error")

  // Deal Blast overrides (Fix 5) — wholesalers show different numbers to buyers
  dealBlastAskingOverride        Decimal? @db.Decimal(12, 2) @map("deal_blast_asking_override")
  dealBlastArvOverride           Decimal? @db.Decimal(12, 2) @map("deal_blast_arv_override")
  dealBlastContractOverride      Decimal? @db.Decimal(12, 2) @map("deal_blast_contract_override")
  dealBlastAssignmentFeeOverride Decimal? @db.Decimal(12, 2) @map("deal_blast_assignment_fee_override")

  // Flexible custom fields per tenant config
  customFields Json @default("{}") @map("custom_fields")

  // Relations
  sellers    PropertySeller[]
  teamMembers PropertyTeamMember[]
  calls      Call[]
  tasks      Task[]
  dealBlasts DealBlast[]
  milestones PropertyMilestone[]
  outreachLogs OutreachLog[]
  buyerStages PropertyBuyerStage[]

  @@map("properties")
}

// ─────────────────────────────────────────
// PROPERTY MILESTONES — deal progress tracking
// ─────────────────────────────────────────

model PropertyMilestone {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId  String @map("tenant_id")
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  type       MilestoneType
  loggedById String? @map("logged_by_id")
  loggedBy   User?   @relation("MilestoneLoggedBy", fields: [loggedById], references: [id])
  source     String  @default("MANUAL") // "MANUAL" | "AUTO_WEBHOOK"
  notes      String?

  @@map("property_milestones")
}

enum MilestoneType {
  // Acquisition pipeline
  LEAD
  APPOINTMENT_SET
  OFFER_MADE
  UNDER_CONTRACT
  CLOSED
  // Disposition pipeline
  DISPO_NEW
  DISPO_PUSHED
  DISPO_OFFER_RECEIVED
  DISPO_CONTRACTED
  DISPO_CLOSED

  @@map("milestone_type")
}

enum PropertyStatus {
  NEW_LEAD
  CONTACTED
  APPOINTMENT_SET
  APPOINTMENT_COMPLETED
  OFFER_MADE
  UNDER_CONTRACT
  // Disposition pipeline stages
  IN_DISPOSITION
  DISPO_PUSHED
  DISPO_OFFERS
  DISPO_CONTRACTED
  DISPO_CLOSED
  // Terminal + long-term
  SOLD
  FOLLOW_UP
  DEAD

  @@map("property_status")
}

// ─────────────────────────────────────────
// SELLERS
// People who own properties
// One seller can have multiple properties
// ─────────────────────────────────────────

model Seller {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── Identity & Contact ──────────────────
  name             String
  phone            String?
  secondaryPhone   String?  @map("secondary_phone")
  mobilePhone      String?  @map("mobile_phone")
  email            String?
  secondaryEmail   String?  @map("secondary_email")
  mailingAddress   String?  @map("mailing_address")
  mailingCity      String?  @map("mailing_city")
  mailingState     String?  @map("mailing_state")
  mailingZip       String?  @map("mailing_zip")
  dateOfBirth      DateTime? @map("date_of_birth")
  maritalStatus    String?  @map("marital_status")   // single | married | divorced | widowed
  spouseName       String?  @map("spouse_name")
  spousePhone      String?  @map("spouse_phone")
  spouseEmail      String?  @map("spouse_email")
  occupation       String?
  employer         String?
  preferredContactMethod String? @map("preferred_contact_method") // call | text | email
  bestTimeToCall   String?  @map("best_time_to_call")
  languagePreference String? @map("language_preference")
  doNotContact     Boolean  @default(false) @map("do_not_contact")
  isDeceased       Boolean  @default(false) @map("is_deceased")

  // ── GHL ─────────────────────────────────
  ghlContactId     String?  @map("ghl_contact_id")

  // ── Property Ownership ──────────────────
  yearsOwned             Int?     @map("years_owned")
  howAcquired            String?  @map("how_acquired")       // inherited | purchased | gift | other
  ownershipType          String?  @map("ownership_type")     // sole | joint | trust | LLC | estate
  entityName             String?  @map("entity_name")        // trust/LLC name
  mortgageBalance        Decimal? @db.Decimal(12, 2) @map("mortgage_balance")
  monthlyMortgagePayment Decimal? @db.Decimal(12, 2) @map("monthly_mortgage_payment")
  lenderName             String?  @map("lender_name")
  interestRate           Float?   @map("interest_rate")
  loanType               String?  @map("loan_type")          // conventional | FHA | VA | hard_money | other
  remainingTermMonths    Int?     @map("remaining_term_months")
  hasSecondMortgage      Boolean? @map("has_second_mortgage")
  secondMortgageBalance  Decimal? @db.Decimal(12, 2) @map("second_mortgage_balance")
  hasHoa                 Boolean? @map("has_hoa")
  hoaAmount              Decimal? @db.Decimal(12, 2) @map("hoa_amount")
  hoaStatus              String?  @map("hoa_status")         // current | delinquent
  propertyTaxesCurrent   Boolean? @map("property_taxes_current")
  propertyTaxesOwed      Decimal? @db.Decimal(12, 2) @map("property_taxes_owed")
  hasLiens               Boolean? @map("has_liens")
  lienAmount             Decimal? @db.Decimal(12, 2) @map("lien_amount")
  lienType               String?  @map("lien_type")
  isProbate              Boolean? @map("is_probate")
  isEstate               Boolean? @map("is_estate")
  estateAttorneyName     String?  @map("estate_attorney_name")
  estateAttorneyPhone    String?  @map("estate_attorney_phone")

  // ── Motivation & Situation ───────────────
  motivationPrimary      String?  @map("motivation_primary")   // inheritance | divorce | foreclosure | tired_landlord | relocation | health | financial | other
  motivationSecondary    String?  @map("motivation_secondary")
  situation              String?  @db.Text                      // free text: full story
  urgencyScore           Int?     @map("urgency_score")         // 1-10
  urgencyLevel           String?  @map("urgency_level")         // high | medium | low | unknown
  saleTimeline           String?  @map("sale_timeline")         // ASAP | 30_days | 60_days | 90_days | flexible
  hardshipType           String?  @map("hardship_type")         // financial | divorce | death | relocation | tired_landlord | health | other
  isDivorce              Boolean? @map("is_divorce")
  isForeclosure          Boolean? @map("is_foreclosure")
  foreclosureAuctionDate DateTime? @map("foreclosure_auction_date")
  isBankruptcy           Boolean? @map("is_bankruptcy")
  isPreProbate           Boolean? @map("is_pre_probate")
  isRecentlyInherited    Boolean? @map("is_recently_inherited")
  behindOnPayments       Boolean? @map("behind_on_payments")
  monthsBehindOnPayments Int?     @map("months_behind_on_payments")
  lifeEventNotes         String?  @db.Text @map("life_event_notes")
  emotionalState         String?  @map("emotional_state")       // distressed | neutral | motivated | testing
  decisionMakers         String?  @map("decision_makers")       // spouse, family, attorney, etc.
  isDecisionMakersConfirmed Boolean? @map("is_decision_makers_confirmed")
  isTenantOccupied       Boolean? @map("is_tenant_occupied")
  tenantLeaseEndDate     DateTime? @map("tenant_lease_end_date")
  isTenantPaying         Boolean? @map("is_tenant_paying")
  isEvictionInProgress   Boolean? @map("is_eviction_in_progress")
  isVacant               Boolean? @map("is_vacant")
  vacantDurationMonths   Int?     @map("vacant_duration_months")
  isListedWithAgent      Boolean? @map("is_listed_with_agent")
  agentName              String?  @map("agent_name")
  agentListingExpiration DateTime? @map("agent_listing_expiration")
  willingToDoSellerFinancing Boolean? @map("willing_to_do_seller_financing")
  willingToDoSubjectTo   Boolean? @map("willing_to_do_subject_to")
  moveOutTimeline        String?  @map("move_out_timeline")

  // ── Financial ───────────────────────────
  sellerAskingPrice      Decimal? @db.Decimal(12, 2) @map("seller_asking_price")   // what seller wants
  lowestAcceptablePrice  Decimal? @db.Decimal(12, 2) @map("lowest_acceptable_price")
  amountNeededToClear    Decimal? @db.Decimal(12, 2) @map("amount_needed_to_clear")
  askingReason           String?  @db.Text @map("asking_reason")  // why they need that price
  financialDistressScore Int?     @map("financial_distress_score") // 1-10 AI
  monthlyCarryingCost    Decimal? @db.Decimal(12, 2) @map("monthly_carrying_cost")
  hasInsurance           Boolean? @map("has_insurance")
  insuranceCompany       String?  @map("insurance_company")

  // ── Interaction History ──────────────────
  firstContactDate              DateTime? @map("first_contact_date")
  lastContactDate               DateTime? @map("last_contact_date")
  totalCallCount                Int       @default(0) @map("total_call_count")
  lastCallOutcome               String?   @map("last_call_outcome")
  responseRate                  Float?    @map("response_rate")       // 0-1
  callsToAppointmentRatio       Float?    @map("calls_to_appointment_ratio")
  bestDayToCall                 String?   @map("best_day_to_call")
  noAnswerStreak                Int       @default(0) @map("no_answer_streak")
  textResponseRate              Float?    @map("text_response_rate")
  sentimentTrend                String?   @map("sentiment_trend")    // improving | declining | neutral
  commonObjections              Json      @default("[]") @map("common_objections")
  rapportScore                  Float?    @map("rapport_score")       // 0-10 AI
  engagementLevel               String?   @map("engagement_level")   // high | medium | low | none
  lastMeaningfulConversationDate DateTime? @map("last_meaningful_conversation_date")

  // ── Lead & Pipeline ─────────────────────
  leadSource      String?   @map("lead_source")
  leadDate        DateTime? @map("lead_date")
  assignedToId    String?   @map("assigned_to_id")
  campaignName    String?   @map("campaign_name")
  listName        String?   @map("list_name")
  timesRecycled   Int       @default(0) @map("times_recycled")
  referralSource  String?   @map("referral_source")
  leadScore       Float?    @map("lead_score") // 0-100 AI

  // ── AI Enriched ─────────────────────────
  motivationScore            Float?  @map("motivation_score")          // 0-1
  likelihoodToSellScore      Float?  @map("likelihood_to_sell_score")  // 0-1
  personalityType            String? @map("personality_type")          // analytical | driver | expressive | amiable
  communicationStyle         String? @map("communication_style")
  priceSensitivity           String? @map("price_sensitivity")         // high | medium | low
  objectionProfile           Json    @default("[]") @map("objection_profile")
  recommendedApproach        String? @db.Text @map("recommended_approach")
  redFlags                   Json    @default("[]") @map("red_flags")
  positiveSignals            Json    @default("[]") @map("positive_signals")
  priceReductionLikelihood   Float?  @map("price_reduction_likelihood") // 0-1
  isSubjectToCandidate       Boolean? @map("is_subject_to_candidate")
  isCreativeFinanceCandidate Boolean? @map("is_creative_finance_candidate")
  followUpPriority           String? @map("follow_up_priority")         // urgent | high | medium | low
  predictedCloseProbability  Float?  @map("predicted_close_probability") // 0-1
  daysToCloseEstimate        Int?    @map("days_to_close_estimate")
  aiSummary                  String? @db.Text @map("ai_summary")
  aiCoachingNotes            String? @db.Text @map("ai_coaching_notes")
  lastAiAnalysisDate         DateTime? @map("last_ai_analysis_date")

  // ── Public Records / Enrichment ─────────
  countyOwnerName      String?   @map("county_owner_name")
  countyAssessedValue  Decimal?  @db.Decimal(12, 2) @map("county_assessed_value")
  countyMarketValue    Decimal?  @db.Decimal(12, 2) @map("county_market_value")
  lastSalePrice        Decimal?  @db.Decimal(12, 2) @map("last_sale_price")
  lastSaleDate         DateTime? @map("last_sale_date")
  parcelId             String?   @map("parcel_id")
  legalDescription     String?   @db.Text @map("legal_description")
  deedType             String?   @map("deed_type")
  zoning               String?
  schoolDistrict       String?   @map("school_district")
  floodZone            String?   @map("flood_zone")
  neighborhoodRating   Float?    @map("neighborhood_rating")
  walkScore            Int?      @map("walk_score")
  crimeScore           Int?      @map("crime_score")
  naturalDisasterRisk  String?   @map("natural_disaster_risk")
  foreclosureHistoryCount Int?   @map("foreclosure_history_count")
  environmentalFlags   Json      @default("[]") @map("environmental_flags")
  enrichmentStatus     String?   @map("enrichment_status")      // pending | complete | failed
  enrichmentLastUpdated DateTime? @map("enrichment_last_updated")

  // ── Appointment & Visit ──────────────────
  appointmentSetDate         DateTime? @map("appointment_set_date")
  appointmentCompletedDate   DateTime? @map("appointment_completed_date")
  walkThroughCompleted       Boolean?  @map("walk_through_completed")
  walkThroughNotes           String?   @db.Text @map("walk_through_notes")
  photosTaken                Boolean?  @map("photos_taken")
  interiorConditionRepNotes  String?   @db.Text @map("interior_condition_rep_notes")
  exteriorConditionRepNotes  String?   @db.Text @map("exterior_condition_rep_notes")
  neighborhoodConditionNotes String?   @db.Text @map("neighborhood_condition_notes")
  accessNotes                String?   @db.Text @map("access_notes")

  // ── General ──────────────────────────────
  tags          Json    @default("[]")
  internalNotes String? @db.Text @map("internal_notes")
  priorityFlag  Boolean @default(false) @map("priority_flag")
  customFields  Json    @default("{}") @map("custom_fields")
