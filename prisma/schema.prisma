  googlePlaceId           String?  @map("google_place_id")
  googleVerifiedAddress   String?  @map("google_verified_address")
  googleLatitude          Decimal? @db.Decimal(10, 8) @map("google_latitude")
  googleLongitude         Decimal? @db.Decimal(11, 8) @map("google_longitude")
  googleStreetViewUrl     String?  @map("google_street_view_url")
  googleMapsUrl           String?  @map("google_maps_url")
  googlePlaceTypes        Json     @default("[]") @map("google_place_types")
  googlePhotoThumbnailUrl String?  @map("google_photo_thumbnail_url")
  googleSearchedAt        DateTime? @map("google_searched_at")

  // Flexible custom fields per tenant config
  customFields Json @default("{}") @map("custom_fields")

  // Relations
  sellers    PropertySeller[]
  teamMembers PropertyTeamMember[]
  calls      Call[]
  tasks      Task[]
  dealBlasts DealBlast[]
  milestones PropertyMilestone[]
  outreachLogs OutreachLog[]
  buyerStages PropertyBuyerStage[]

  @@index([county])
  @@index([apn])
  @@index([absenteeOwner])
  @@index([taxDelinquent])
  @@index([foreclosureStatus])
  @@index([preForeclosure])
  @@index([vacantStatus])
  @@index([distressScore])
  @@index([inBankruptcy])
  @@index([inProbate])
  @@index([isListedForSale])
  @@index([mlsActive])
  @@index([googlePlaceId])
  @@index([investorType])
  @@index([improvementCondition])
  @@index([buildingQuality])
  @@index([advancedPropertyType])
  @@index([seniorOwner])
  @@index([deceasedOwner])
  @@index([hasOpenLiens])
  @@index([salePropensity])
  @@map("properties")
}

// ─────────────────────────────────────────
// PROPERTY MILESTONES — deal progress tracking
// ─────────────────────────────────────────

model PropertyMilestone {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId  String @map("tenant_id")
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  type       MilestoneType
  loggedById String? @map("logged_by_id")
  loggedBy   User?   @relation("MilestoneLoggedBy", fields: [loggedById], references: [id])
  source     String  @default("MANUAL") // "MANUAL" | "AUTO_WEBHOOK"
  notes      String?

  @@map("property_milestones")
}

enum MilestoneType {
  // Acquisition pipeline
  LEAD
  APPOINTMENT_SET
  OFFER_MADE
  UNDER_CONTRACT
  CLOSED
  // Disposition pipeline
  DISPO_NEW
  DISPO_PUSHED
  DISPO_OFFER_RECEIVED
  DISPO_CONTRACTED
  DISPO_CLOSED

  @@map("milestone_type")
}

enum PropertyStatus {
  NEW_LEAD
  CONTACTED
  APPOINTMENT_SET
  APPOINTMENT_COMPLETED
  OFFER_MADE
  UNDER_CONTRACT
  // Disposition pipeline stages
  IN_DISPOSITION
  DISPO_PUSHED
  DISPO_OFFERS
  DISPO_CONTRACTED
  DISPO_CLOSED
  // Terminal + long-term
  SOLD
  FOLLOW_UP
  DEAD

  @@map("property_status")
}

// ─────────────────────────────────────────
// SELLERS
// People who own properties
// One seller can have multiple properties
// ─────────────────────────────────────────

model Seller {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ── Identity & Contact ──────────────────
  // Legacy name column — drops in v1.1 Wave 5 cutover. UI reads decomposed
  // parts (firstName/middleName/lastName/nameSuffix) post-cutover.
  name             String
  // Q2 lock (v1.1 Wave 1) — decomposed name parts. CourtListener exact-name
  // search and skip-trace match quality both need structured form.
  firstName        String?  @map("first_name")
  middleName       String?  @map("middle_name")
  lastName         String?  @map("last_name")
  nameSuffix       String?  @map("name_suffix")
  // Legacy GHL-overlap identity columns — drop in v1.1 Wave 5 cutover.
  // Render path post-cutover: live-fetch from GHL via ghlContactId, with
  // skipTraced* below as fallback when ghlContactId is null.
  phone            String?
  secondaryPhone   String?  @map("secondary_phone")
  mobilePhone      String?  @map("mobile_phone")
  email            String?
  secondaryEmail   String?  @map("secondary_email")
  mailingAddress   String?  @map("mailing_address")
  mailingCity      String?  @map("mailing_city")
  mailingState     String?  @map("mailing_state")
  mailingZip       String?  @map("mailing_zip")
  mailingZipPlus4  String?  @map("mailing_zip_plus4")
  mailingCounty    String?  @map("mailing_county")
  // Q1/Shape A lock (v1.1 Wave 1) — skip-trace fallback identity. Used when
  // ghlContactId is null (skip-traced sellers not yet promoted to GHL contacts).
  // Once promoted, these become orphan history (kept for audit).
  skipTracedPhone           String?  @map("skip_traced_phone")
  skipTracedEmail           String?  @map("skip_traced_email")
  skipTracedMailingAddress  String?  @map("skip_traced_mailing_address")
  skipTracedMailingCity     String?  @map("skip_traced_mailing_city")
  skipTracedMailingState    String?  @map("skip_traced_mailing_state")
  skipTracedMailingZip      String?  @map("skip_traced_mailing_zip")
  mailingValidity  String?  @map("mailing_validity")
  mailingDeliveryPoint String? @map("mailing_delivery_point")
  mailingDpvFootnotes  String? @map("mailing_dpv_footnotes")
  mailingDpvMatchCode  String? @map("mailing_dpv_match_code")
  dateOfBirth      DateTime? @map("date_of_birth")
  maritalStatus    String?  @map("marital_status")   // single | married | divorced | widowed
  spouseName       String?  @map("spouse_name")
  spousePhone      String?  @map("spouse_phone")
  spouseEmail      String?  @map("spouse_email")
  occupation       String?
  employer         String?
  preferredContactMethod String? @map("preferred_contact_method") // call | text | email
  bestTimeToCall   String?  @map("best_time_to_call")
  languagePreference String? @map("language_preference")
  doNotContact     Boolean  @default(false) @map("do_not_contact")
  isDeceased       Boolean  @default(false) @map("is_deceased")
  // PropertyRadar /persons demographics
  age              Int?
  gender           String?
  personType       String?  @map("person_type")   // "Person" | "Company"

  // ── GHL ─────────────────────────────────
  ghlContactId     String?  @map("ghl_contact_id")

  // ── Property Ownership ──────────────────
  yearsOwned             Int?     @map("years_owned")
  howAcquired            String?  @map("how_acquired")       // inherited | purchased | gift | other
  ownershipType          String?  @map("ownership_type")     // sole | joint | trust | LLC | estate
  entityName             String?  @map("entity_name")        // trust/LLC name
  mortgageBalance        Decimal? @db.Decimal(12, 2) @map("mortgage_balance")
  monthlyMortgagePayment Decimal? @db.Decimal(12, 2) @map("monthly_mortgage_payment")
  lenderName             String?  @map("lender_name")
  interestRate           Float?   @map("interest_rate")
  loanType               String?  @map("loan_type")          // conventional | FHA | VA | hard_money | other
  remainingTermMonths    Int?     @map("remaining_term_months")
  hasSecondMortgage      Boolean? @map("has_second_mortgage")
  secondMortgageBalance  Decimal? @db.Decimal(12, 2) @map("second_mortgage_balance")
  hasHoa                 Boolean? @map("has_hoa")
  hoaAmount              Decimal? @db.Decimal(12, 2) @map("hoa_amount")
  hoaStatus              String?  @map("hoa_status")         // current | delinquent
  propertyTaxesCurrent   Boolean? @map("property_taxes_current")
  propertyTaxesOwed      Decimal? @db.Decimal(12, 2) @map("property_taxes_owed")
  hasLiens               Boolean? @map("has_liens")
  lienAmount             Decimal? @db.Decimal(12, 2) @map("lien_amount")
  lienType               String?  @map("lien_type")
  isProbate              Boolean? @map("is_probate")
  isEstate               Boolean? @map("is_estate")
  estateAttorneyName     String?  @map("estate_attorney_name")
  estateAttorneyPhone    String?  @map("estate_attorney_phone")

  // ── Motivation & Situation ───────────────
  motivationPrimary      String?  @map("motivation_primary")   // inheritance | divorce | foreclosure | tired_landlord | relocation | health | financial | other
  motivationSecondary    String?  @map("motivation_secondary")
  situation              String?  @db.Text                      // free text: full story
  urgencyScore           Int?     @map("urgency_score")         // 1-10
  urgencyLevel           String?  @map("urgency_level")         // high | medium | low | unknown
  saleTimeline           String?  @map("sale_timeline")         // ASAP | 30_days | 60_days | 90_days | flexible
  hardshipType           String?  @map("hardship_type")         // financial | divorce | death | relocation | tired_landlord | health | other
  isDivorce              Boolean? @map("is_divorce")
  isForeclosure          Boolean? @map("is_foreclosure")
  foreclosureAuctionDate DateTime? @map("foreclosure_auction_date")
  isBankruptcy           Boolean? @map("is_bankruptcy")
  isPreProbate           Boolean? @map("is_pre_probate")
  isRecentlyInherited    Boolean? @map("is_recently_inherited")
  behindOnPayments       Boolean? @map("behind_on_payments")
  monthsBehindOnPayments Int?     @map("months_behind_on_payments")
  lifeEventNotes         String?  @db.Text @map("life_event_notes")
  emotionalState         String?  @map("emotional_state")       // distressed | neutral | motivated | testing
  decisionMakers         String?  @map("decision_makers")       // spouse, family, attorney, etc.
  isDecisionMakersConfirmed Boolean? @map("is_decision_makers_confirmed")
  isTenantOccupied       Boolean? @map("is_tenant_occupied")
  tenantLeaseEndDate     DateTime? @map("tenant_lease_end_date")
  isTenantPaying         Boolean? @map("is_tenant_paying")
  isEvictionInProgress   Boolean? @map("is_eviction_in_progress")
  isVacant               Boolean? @map("is_vacant")
  vacantDurationMonths   Int?     @map("vacant_duration_months")
  isListedWithAgent      Boolean? @map("is_listed_with_agent")
  agentName              String?  @map("agent_name")
  agentListingExpiration DateTime? @map("agent_listing_expiration")
  willingToDoSellerFinancing Boolean? @map("willing_to_do_seller_financing")
  willingToDoSubjectTo   Boolean? @map("willing_to_do_subject_to")
  moveOutTimeline        String?  @map("move_out_timeline")

  // ── Financial ───────────────────────────
  sellerAskingPrice      Decimal? @db.Decimal(12, 2) @map("seller_asking_price")   // what seller wants
  lowestAcceptablePrice  Decimal? @db.Decimal(12, 2) @map("lowest_acceptable_price")
  amountNeededToClear    Decimal? @db.Decimal(12, 2) @map("amount_needed_to_clear")
  askingReason           String?  @db.Text @map("asking_reason")  // why they need that price
  financialDistressScore Int?     @map("financial_distress_score") // 1-10 AI
  monthlyCarryingCost    Decimal? @db.Decimal(12, 2) @map("monthly_carrying_cost")
  hasInsurance           Boolean? @map("has_insurance")
  insuranceCompany       String?  @map("insurance_company")

  // ── Interaction History ──────────────────
  firstContactDate              DateTime? @map("first_contact_date")
  lastContactDate               DateTime? @map("last_contact_date")
  totalCallCount                Int       @default(0) @map("total_call_count")
  lastCallOutcome               String?   @map("last_call_outcome")
  responseRate                  Float?    @map("response_rate")       // 0-1
  callsToAppointmentRatio       Float?    @map("calls_to_appointment_ratio")
  bestDayToCall                 String?   @map("best_day_to_call")
  noAnswerStreak                Int       @default(0) @map("no_answer_streak")
  textResponseRate              Float?    @map("text_response_rate")
  sentimentTrend                String?   @map("sentiment_trend")    // improving | declining | neutral
  commonObjections              Json      @default("[]") @map("common_objections")
  rapportScore                  Float?    @map("rapport_score")       // 0-10 AI
  engagementLevel               String?   @map("engagement_level")   // high | medium | low | none
  lastMeaningfulConversationDate DateTime? @map("last_meaningful_conversation_date")

  // ── Lead & Pipeline ─────────────────────
  leadSource      String?   @map("lead_source")
  leadDate        DateTime? @map("lead_date")
  assignedToId    String?   @map("assigned_to_id")
  campaignName    String?   @map("campaign_name")
  listName        String?   @map("list_name")
  timesRecycled   Int       @default(0) @map("times_recycled")
  referralSource  String?   @map("referral_source")
  leadScore       Float?    @map("lead_score") // 0-100 AI

  // ── AI Enriched ─────────────────────────
  motivationScore            Float?  @map("motivation_score")          // 0-1
  likelihoodToSellScore      Float?  @map("likelihood_to_sell_score")  // 0-1
  personalityType            String? @map("personality_type")          // analytical | driver | expressive | amiable
  communicationStyle         String? @map("communication_style")
  priceSensitivity           String? @map("price_sensitivity")         // high | medium | low
  objectionProfile           Json    @default("[]") @map("objection_profile")
  recommendedApproach        String? @db.Text @map("recommended_approach")
  redFlags                   Json    @default("[]") @map("red_flags")
  positiveSignals            Json    @default("[]") @map("positive_signals")
  priceReductionLikelihood   Float?  @map("price_reduction_likelihood") // 0-1
  isSubjectToCandidate       Boolean? @map("is_subject_to_candidate")
  isCreativeFinanceCandidate Boolean? @map("is_creative_finance_candidate")
  followUpPriority           String? @map("follow_up_priority")         // urgent | high | medium | low
  predictedCloseProbability  Float?  @map("predicted_close_probability") // 0-1
  daysToCloseEstimate        Int?    @map("days_to_close_estimate")
  aiSummary                  String? @db.Text @map("ai_summary")
  aiCoachingNotes            String? @db.Text @map("ai_coaching_notes")
  lastAiAnalysisDate         DateTime? @map("last_ai_analysis_date")

  // ── Public Records / Enrichment ─────────
  countyOwnerName      String?   @map("county_owner_name")
  countyAssessedValue  Decimal?  @db.Decimal(12, 2) @map("county_assessed_value")
  countyMarketValue    Decimal?  @db.Decimal(12, 2) @map("county_market_value")
  lastSalePrice        Decimal?  @db.Decimal(12, 2) @map("last_sale_price")
  lastSaleDate         DateTime? @map("last_sale_date")
  parcelId             String?   @map("parcel_id")
  legalDescription     String?   @db.Text @map("legal_description")
  deedType             String?   @map("deed_type")
  zoning               String?
  schoolDistrict       String?   @map("school_district")
  floodZone            String?   @map("flood_zone")
  neighborhoodRating   Float?    @map("neighborhood_rating")
  walkScore            Int?      @map("walk_score")
  crimeScore           Int?      @map("crime_score")
  naturalDisasterRisk  String?   @map("natural_disaster_risk")
  foreclosureHistoryCount Int?   @map("foreclosure_history_count")
  environmentalFlags   Json      @default("[]") @map("environmental_flags")
  enrichmentStatus     String?   @map("enrichment_status")      // pending | complete | failed
  enrichmentLastUpdated DateTime? @map("enrichment_last_updated")

  // ── Appointment & Visit ──────────────────
  appointmentSetDate         DateTime? @map("appointment_set_date")
  appointmentCompletedDate   DateTime? @map("appointment_completed_date")
  walkThroughCompleted       Boolean?  @map("walk_through_completed")
  walkThroughNotes           String?   @db.Text @map("walk_through_notes")
  photosTaken                Boolean?  @map("photos_taken")
  interiorConditionRepNotes  String?   @db.Text @map("interior_condition_rep_notes")
  exteriorConditionRepNotes  String?   @db.Text @map("exterior_condition_rep_notes")
  neighborhoodConditionNotes String?   @db.Text @map("neighborhood_condition_notes")
  accessNotes                String?   @db.Text @map("access_notes")

  // ── Call voice / emotion aggregates (from Claude call extraction) ─
  // Promoted from the dealIntel JSON blob to typed columns so we can filter.
  // Trust arc is an append-only array of {step, callId, calledAt} so we can
  // visualize how trust moves across calls without recomputing.
  trustScore             Int?     @map("trust_score")               // 0-100, composite
  trustStepCurrent       String?  @map("trust_step_current")        // distrustful | neutral | warming | trusting
  trustStepArc           Json     @default("[]") @map("trust_step_arc")
  voiceEnergyTrend       String?  @map("voice_energy_trend")        // declining | stable | rising
  primaryEmotionMostFrequent String? @map("primary_emotion_most_frequent") // anxious | hopeful | resigned | angry | grief | defensive
  competitorsMentionedByName Json  @default("[]") @map("competitors_mentioned_by_name")
  dealkillersRaised      Json     @default("[]") @map("dealkillers_raised")

  // ── Message aggregates (computed nightly from messages — once persisted) ─
  messageResponseTimeAvgHours Float?   @map("message_response_time_avg_hours")
  messageResponseRate         Float?   @map("message_response_rate")
  messageBestReplyHourOfDay   Int?     @map("message_best_reply_hour_of_day")
  messageBestReplyDayOfWeek   String?  @map("message_best_reply_day_of_week")
  messageThreadSentimentTrend String?  @map("message_thread_sentiment_trend") // warming | flat | cooling
  messageGhostCheckpoint      Int?     @map("message_ghost_checkpoint")       // # messages in before ghost
  lastMessageReceivedAt       DateTime? @map("last_message_received_at")

  // ── Portfolio aggregates (computed from PropertySeller + Property) ───
  totalPropertiesOwned    Int      @default(0) @map("total_properties_owned")
  totalPropertiesSoldToUs Int      @default(0) @map("total_properties_sold_to_us")
  portfolioMarkets        Json     @default("[]") @map("portfolio_markets")
  totalDealsWithUs        Int      @default(0) @map("total_deals_with_us")
  totalDealsClosed        Int      @default(0) @map("total_deals_closed")
  totalDealsWalked        Int      @default(0) @map("total_deals_walked")
  avgDaysToClose          Int?     @map("avg_days_to_close")
  lastDealClosedDate      DateTime? @map("last_deal_closed_date")
  closeRate               Float?   @map("close_rate")

  // ── Owner portfolio (vendor-extracted, v1.1 Wave 1 — stripped from Property) ─
  // PropertyRadar / BatchData ship cross-portfolio totals on the OWNER, not on
  // any one property. These were on Property pre-v1.1 (staging-via-Property);
  // post-v1.1 they live on Seller, where the person is the unit. Property-side
  // duplicates drop in Wave 5 cutover.
  ownerPortfolioTotalEquity   Decimal? @db.Decimal(14, 2) @map("owner_portfolio_total_equity")
  ownerPortfolioTotalValue    Decimal? @db.Decimal(14, 2) @map("owner_portfolio_total_value")
  ownerPortfolioTotalPurchase Decimal? @db.Decimal(14, 2) @map("owner_portfolio_total_purchase")
  ownerPortfolioAvgAssessed   Decimal? @db.Decimal(14, 2) @map("owner_portfolio_avg_assessed")
  ownerPortfolioAvgPurchase   Decimal? @db.Decimal(14, 2) @map("owner_portfolio_avg_purchase")
  ownerPortfolioAvgYearBuilt  Int?     @map("owner_portfolio_avg_year_built")
  ownerPortfolioJson          Json?    @map("owner_portfolio_json")

  // Q3 lock (v1.1 Wave 1) — person-level flags stripped from Property.
  // PropertyRadar reports these about the OWNER record, not the property.
  seniorOwner             Boolean? @map("senior_owner")
  deceasedOwner           Boolean? @map("deceased_owner")
  cashBuyerOwner          Boolean? @map("cash_buyer_owner")

  // ── Relationship + comm prefs (mostly manual, some computed) ─────────
  whoReferredThem          String?  @map("who_referred_them")
  contactResponsivenessTier String?  @map("contact_responsiveness_tier") // A | B | C | flaky
  doNotText                Boolean  @default(false) @map("do_not_text")
  preferredContactTime     String?  @map("preferred_contact_time") // morning | afternoon | evening | any
  relationshipStrength     String?  @map("relationship_strength")  // new | warming | established | cold

  // ── Cross-portfolio financial posture (not per-property) ─────────────
  overallFinancialPressureTier String? @map("overall_financial_pressure_tier") // A | B | C | stable
  liquidityPosture             String? @map("liquidity_posture")  // cash-heavy | income-stable | constrained | distressed
  creditProxyTier              String? @map("credit_proxy_tier")  // strong | middle | weak
  bankruptcyHistoryFlag        Boolean @default(false) @map("bankruptcy_history_flag")

  // ── Public-records scan (person-level — federal + state court lookups) ─
  federalBankruptcyActive      Boolean @default(false) @map("federal_bankruptcy_active")
  federalBankruptcyChapter     String? @map("federal_bankruptcy_chapter") // 7 | 13 | other
  civilSuitCountAsDefendant    Int     @default(0) @map("civil_suit_count_as_defendant")
  divorceActiveFlag            Boolean @default(false) @map("divorce_active_flag")
  evictionFilingCountAsPlaintiff Int   @default(0) @map("eviction_filing_count_as_plaintiff")
  evictionFilingCountAsDefendant Int   @default(0) @map("eviction_filing_count_as_defendant")
  publicRecordsLastScan        DateTime? @map("public_records_last_scan")

  // ── CourtListener automated case search ──────────────────────────────
  // Populated by lib/courtlistener/client.ts on each property enrichment
  // that has a linked Seller. Replaces the older manual public-records
  // fields above for new sellers — existing rows keep both.
  clCasesSearchedAt            DateTime? @map("cl_cases_searched_at")
  clCasesJson                  Json      @default("[]") @map("cl_cases_json")
  clBankruptcyCount            Int       @default(0) @map("cl_bankruptcy_count")
  clBankruptcyLatestChapter    String?   @map("cl_bankruptcy_latest_chapter")
  clBankruptcyLatestFilingDate DateTime? @map("cl_bankruptcy_latest_filing_date")
  clBankruptcyLatestStatus     String?   @map("cl_bankruptcy_latest_status")
  clBankruptcyLatestCourt      String?   @map("cl_bankruptcy_latest_court")
  clDivorceCount               Int       @default(0) @map("cl_divorce_count")
  clDivorceLatestFilingDate    DateTime? @map("cl_divorce_latest_filing_date")
  clCivilJudgmentCount         Int       @default(0) @map("cl_civil_judgment_count")
  clCivilJudgmentLatestDate    DateTime? @map("cl_civil_judgment_latest_date")
  clForeclosureCourtCaseDate   DateTime? @map("cl_foreclosure_court_case_date")
  clProbateCount               Int       @default(0) @map("cl_probate_count")
  clProbateLatestFilingDate    DateTime? @map("cl_probate_latest_filing_date")

  // ── General ──────────────────────────────
  tags          Json    @default("[]")
  internalNotes String? @db.Text @map("internal_notes")
  priorityFlag  Boolean @default(false) @map("priority_flag")
  customFields  Json    @default("{}") @map("custom_fields")
  fieldSources  Json    @default("{}") @map("field_sources") // tracks AI | API | manual per field

  // ── Relations ────────────────────────────
  properties PropertySeller[]
  calls      Call[]

  @@index([tenantId, phone])
  @@map("sellers")
}

model PropertySeller {
  propertyId String   @map("property_id")
  sellerId   String   @map("seller_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  seller     Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(false) @map("is_primary")
  role       String   @default("Seller") @map("role")

  // ── Deal-state on THIS seller+property pair (from Claude call extraction) ─
  // These are per-call aggregates — latest call wins. Resistance level and
  // current objections reflect the live read on this deal; the seller-level
  // analogs (Seller.objectionProfile, Seller.engagementLevel) aggregate across
  // all of their properties.
  sellerResistanceLevel  String?   @map("seller_resistance_level") // eager | neutral | reluctant | hostile
  lastConversationSummary String?  @db.Text @map("last_conversation_summary")
  nextFollowupDate       DateTime? @map("next_followup_date")
  competingOffersCount   Int       @default(0) @map("competing_offers_count")
  sellerTimelineConstraint String? @map("seller_timeline_constraint") // asap | 30_days | flexible | no_rush
  estimatedDaysToDecision Int?     @map("estimated_days_to_decision")
  currentObjections      Json      @default("[]") @map("current_objections")
  negotiationStage       String?   @map("negotiation_stage")  // initial | anchored | compromising | accepted | declined

  @@id([propertyId, sellerId])
  @@map("property_sellers")
}

// ─────────────────────────────────────────
// PROPERTY TEAM MEMBERS — multiple users per property
// ─────────────────────────────────────────

model PropertyTeamMember {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("PropertyTeamMembers", fields: [userId], references: [id], onDelete: Cascade)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  role   String // ADMIN, LEAD_MANAGER, ACQUISITION_MANAGER, DISPOSITION_MANAGER, etc.
  source String @default("manual") // manual, call, milestone

  @@unique([propertyId, userId])
  @@map("property_team_members")
}

// ─────────────────────────────────────────
// CALLS
// Every call graded automatically when it ends
// ─────────────────────────────────────────

model Call {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  // Auto-updated on every row change. Added 2026-04-20 to power the
  // grading-worker rescue sweeps (stuck PROCESSING / auto-retry FAILED).
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Who made/received the call
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("CallAssignedTo", fields: [assignedToId], references: [id])

  // Property this call is about
  propertyId String?  @map("property_id")
  property   Property? @relation(fields: [propertyId], references: [id])

  // GHL data
  ghlCallId    String? @unique @map("ghl_call_id")
  ghlContactId String? @map("ghl_contact_id") // GHL contact ID for AM/PM tracking
  sellerId   String? @map("seller_id")
  seller     Seller? @relation(fields: [sellerId], references: [id])
  buyerId  String? @map("buyer_id")
  buyer    Buyer?  @relation(fields: [buyerId], references: [id])
  contactName    String? @map("contact_name")    // cached from GHL contact
  contactAddress String? @map("contact_address") // cached from GHL contact address1+city+state
  recordingUrl   String? @map("recording_url")
  transcript   String? @db.Text

  // Manual upload (MP3/MP4/transcript paste via /calls/upload) — false for GHL-sourced calls
  manualUpload     Boolean @default(false) @map("manual_upload")
  audioStoragePath String? @map("audio_storage_path") // Supabase Storage path: "{tenantId}/{callId}.{ext}"

  // True when a human explicitly set callOutcome via Reclassify — re-grades
  // MUST preserve the human choice and not let the AI overwrite it.
  outcomeManualOverride Boolean @default(false) @map("outcome_manual_override")

  // Call metadata
  callType     String? @map("call_type")   // from tenant.callTypes config
  callResult   String? @map("call_result") // from tenant.callResults config
  direction    CallDirection @default(OUTBOUND)
  durationSeconds Int? @map("duration_seconds")
  calledAt     DateTime? @map("called_at")
  source       String?  @map("source") // 'webhook' | 'poll' — how this call was ingested

  // AI Grading
  gradingStatus GradingStatus @default(PENDING) @map("grading_status")
  score         Float?        // 0-100
  rubricScores  Json?         @map("rubric_scores") // per-category scores
  aiSummary     String?       @db.Text @map("ai_summary")
  aiFeedback    String?       @db.Text @map("ai_feedback")
  aiCoachingTips Json?        @map("ai_coaching_tips")
  gradedAt      DateTime?     @map("graded_at")

  // AI Analysis (populated during grading)
  sentiment        Float?    // -1.0 to 1.0
  objections       Json?     // [{objection, response, handled}]
  talkRatio        Float?    @map("talk_ratio") // rep talk % vs seller talk %
  keyMoments       Json?     @map("key_moments") // [{timestamp, type, description}]
  callOutcome      String?   @map("call_outcome") // appointment_set, follow_up, dead, contract, not_interested
  sellerMotivation Float?    @map("seller_motivation") // 0.0 to 1.0
  nextBestAction   String?   @map("next_best_action") // AI suggested next step
  aiNextSteps      Json?     @map("ai_next_steps") // [{type, label, reasoning, status, pushedAt}]
  // Deal intel proposed changes from this call — [{field, label, currentValue, proposedValue, confidence, evidence, category, decision, decidedAt}]
  dealIntelHistory  Json?     @map("deal_intel_history")

  // ── Promoted per-call extractions (filterable) ────────────────────────
  // These duplicate signals already captured in dealIntelHistory JSON but
  // promote the highest-leverage fields to typed columns so dashboards and
  // per-seller aggregates can filter cheaply. Each is extracted fresh per
  // call by the Claude extractor and rolled up into Seller-level aggregates
  // (primaryEmotionMostFrequent, dealkillersRaised[], etc.) by the cron.
  callPrimaryEmotion      String?   @map("call_primary_emotion")    // anxious | hopeful | resigned | angry | grief | defensive
  callVoiceEnergyLevel    String?   @map("call_voice_energy_level") // high | medium | low | distressed
  callTrustStep           String?   @map("call_trust_step")         // distrustful | neutral | warming | trusting
  callFollowupCommitment  String?   @db.Text @map("call_followup_commitment") // verbatim agreed next step
  callBestOfferMentioned  Decimal?  @db.Decimal(12, 2) @map("call_best_offer_mentioned")
  callDealkillersSurfaced Json      @default("[]") @map("call_dealkillers_surfaced")
  callCompetitorsMentioned Json     @default("[]") @map("call_competitors_mentioned")

  // Calibration — mark as good/bad example for grading baseline
  isCalibration    Boolean @default(false) @map("is_calibration")
  calibrationNotes String? @map("calibration_notes")

  recordingFetchJob RecordingFetchJob?
  reclassifications CallReclassification[]

  @@map("calls")
}

// ─────────────────────────────────────────
// CALL RECLASSIFICATION EVENTS
// Captures every human correction (call type / outcome) so the AI can later
// learn from disagreements between its classification and the rep's judgment.
// Append-only — never updated or deleted.
// ─────────────────────────────────────────

model CallReclassification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  callId String @map("call_id")
  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation("CallReclassifiedBy", fields: [userId], references: [id])

  // Before/after snapshot — nullable because either type or outcome (or both) may change
  previousCallType    String? @map("previous_call_type")
  newCallType         String? @map("new_call_type")
  previousCallOutcome String? @map("previous_call_outcome")
  newCallOutcome      String? @map("new_call_outcome")

  // Snapshot the AI's justification at the moment of reclassification — lets
  // future training see "what the AI thought" vs. "what the human decided"
  previousAiSummary String? @db.Text @map("previous_ai_summary")

  @@index([tenantId, createdAt])
  @@index([callId])
  @@map("call_reclassifications")
}

// ─────────────────────────────────────────
// RECORDING FETCH JOBS
// Durable job queue for delayed recording fetches (replaces setTimeout)
// ─────────────────────────────────────────

model RecordingFetchJob {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  callId        String   @unique @map("call_id")
  ghlMessageId  String   @map("ghl_message_id")
  attempts      Int      @default(0)
  nextAttemptAt DateTime @map("next_attempt_at")
  status        String   @default("PENDING") // PENDING | DONE | FAILED
  lastError     String?  @map("last_error")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  call          Call     @relation(fields: [callId], references: [id])

  @@index([status, nextAttemptAt])
  @@map("recording_fetch_jobs")
}

enum CallDirection {
  INBOUND
  OUTBOUND

  @@map("call_direction")
}

enum GradingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED

  @@map("grading_status")
}

// ─────────────────────────────────────────
// CALL RUBRICS
// Per-tenant, per-role grading templates
// ─────────────────────────────────────────

model CallRubric {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  role      UserRole // which role this rubric applies to
  callType  String?  @map("call_type") // null = applies to all call types
  name      String
  isDefault Boolean  @default(false) @map("is_default")

