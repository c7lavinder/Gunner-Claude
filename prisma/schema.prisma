// Gunner AI — Prisma Schema
// Source of truth for all database models
// Run: npx prisma migrate dev --name <description>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// TENANTS
// Each paying client is a tenant. Fully isolated.
// ─────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Identity
  name    String
  slug    String  @unique // used in URL: gunnerai.com/{slug}/dashboard
  logoUrl String? @map("logo_url")

  // GHL OAuth (Marketplace App)
  ghlLocationId    String? @unique @map("ghl_location_id")   // sub-account ID
  ghlAccessToken   String? @map("ghl_access_token")
  ghlRefreshToken  String? @map("ghl_refresh_token")
  ghlTokenExpiry   DateTime? @map("ghl_token_expiry")
  ghlWebhookId     String? @map("ghl_webhook_id")

  // Call export cursor — tracks last processed message for reliable call ingestion
  lastCallExportCursor String? @map("last_call_export_cursor")

  // AI Knowledge — company-specific context for grading/coaching
  scripts          Json    @default("{}") @map("scripts")           // keyed by call type: {cold_call: "...", ...}
  companyStandards String? @map("company_standards") @db.Text       // company rules/standards
  calibrationCalls Json    @default("[]") @map("calibration_calls") // [{callId, type: "good"|"bad", notes}]

  // Property trigger config
  propertyPipelineId    String? @map("property_pipeline_id")    // which GHL pipeline (acquisition)
  propertyTriggerStage  String? @map("property_trigger_stage")  // which stage creates a property
  dispoPipelineId       String? @map("dispo_pipeline_id")       // GHL dispo pipeline
  dispoTriggerStage     String? @map("dispo_trigger_stage")     // stage that moves property into dispo

  // Onboarding state
  onboardingStep      Int     @default(0) @map("onboarding_step")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")

  // Stripe subscription
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripePriceId         String?   @map("stripe_price_id")
  subscriptionStatus    String?   @map("subscription_status")   // active, past_due, canceled, trialing
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")

  // Tenant-level config (JSON — flexible per client)
  callTypes    Json @default("[]") @map("call_types")    // ["inbound", "outbound", "followup"]
  callResults  Json @default("[]") @map("call_results")  // ["interested", "not interested", "callback"]
  config       Json @default("{}") // misc config blob

  // Tenant-specific grading materials (scripts, processes, company standards)
  // WRITES TO: tenants.grading_materials (String?)
  // API ENDPOINT: PATCH /api/tenants/config
  // READ BY: lib/ai/grading.ts → buildGradingSystemPrompt()
  gradingMaterials String? @map("grading_materials") @db.Text

  // Relations
  users         User[]
  properties    Property[]
  sellers       Seller[]
  calls         Call[]
  tasks         Task[]
  kpiSnapshots  KpiSnapshot[]
  auditLogs     AuditLog[]
  callRubrics   CallRubric[]
  roleConfigs   RoleConfig[]
  userXp              UserXp[]
  userBadges          UserBadge[]
  xpEvents            XpEvent[]
  leadSourceCosts     LeadSourceCost[]
  coachLogs           CoachLog[]
  workflowDefinitions WorkflowDefinition[]
  workflowExecutions  WorkflowExecution[]
  buyers              Buyer[]
  markets             Market[]
  outreachLogs        OutreachLog[]
  dealBlasts          DealBlast[]
  milestones          PropertyMilestone[]
  propertyBuyerStages PropertyBuyerStage[]
  propertyTeamMembers PropertyTeamMember[]
  knowledgeDocuments  KnowledgeDocument[]
  userProfiles        UserProfile[]
  callReclassifications CallReclassification[]
  assistantMessages   AssistantMessage[]
  actionLogs          ActionLog[]
  aiLogs              AiLog[]
  recordingFetchJobs  RecordingFetchJob[]
  webhookLogs         WebhookLog[]
  contactSuggestions  ContactSuggestion[]
  bugReports          BugReport[]

  @@map("tenants")
}

// ─────────────────────────────────────────
// USERS
// Team members within a tenant
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Auth
  email          String  @unique
  hashedPassword String? @map("hashed_password")
  emailVerified  DateTime? @map("email_verified")

  // Profile
  name      String
  avatarUrl String? @map("avatar_url")
  phone     String?

  // Role + hierarchy
  role      UserRole
  reportsTo String? @map("reports_to") // user id of their manager

  // Manager relation (self-referential)
  manager    User?  @relation("UserReportsTo", fields: [reportsTo], references: [id])
  directReports User[] @relation("UserReportsTo")

  // Per-user config
  kpiConfig       Json @default("{}") @map("kpi_config")       // which KPIs to show
  cardConfig      Json @default("{}") @map("card_config")       // property card layout
  taskSortConfig  Json @default("{}") @map("task_sort_config")  // task list preferences
  dashboardConfig Json @default("{}") @map("dashboard_config")

  // GHL
  ghlUserId String? @map("ghl_user_id")

  // Relations
  assignedCalls      Call[]     @relation("CallAssignedTo")
  assignedTasks      Task[]     @relation("TaskAssignedTo")
  assignedProperties Property[] @relation("PropertyAssignedTo")
  kpiSnapshots       KpiSnapshot[]
  auditLogs          AuditLog[]
  xp                 UserXp?
  badges             UserBadge[]
  xpEvents           XpEvent[]
  coachLogs          CoachLog[]
  dealBlasts         DealBlast[] @relation("BlastCreatedBy")
  loggedMilestones   PropertyMilestone[] @relation("MilestoneLoggedBy")
  outreachLogs       OutreachLog[] @relation("OutreachLogUser")
  propertyTeamMembers PropertyTeamMember[] @relation("PropertyTeamMembers")
  userProfile         UserProfile?
  assistantMessages   AssistantMessage[] @relation("AssistantMessages")
  actionLogs          ActionLog[] @relation("ActionLogs")
  callReclassifications CallReclassification[] @relation("CallReclassifiedBy")

  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  TEAM_LEAD
  LEAD_MANAGER
  ACQUISITION_MANAGER
  DISPOSITION_MANAGER

  @@map("user_role")
}

// ─────────────────────────────────────────
// PROPERTIES (Inventory)
// Core of the wholesaling business
// NOT contacts — one seller can have multiple properties
// ─────────────────────────────────────────

model Property {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Assignment
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("PropertyAssignedTo", fields: [assignedToId], references: [id])

  // Address
  address String
  city    String
  state   String
  zip     String

  // Financial
  arv          Decimal? @db.Decimal(12, 2) // After Repair Value
  askingPrice  Decimal? @db.Decimal(12, 2) @map("asking_price")
  mao          Decimal? @db.Decimal(12, 2) // Max Allowable Offer
  contractPrice Decimal? @db.Decimal(12, 2) @map("contract_price")
  assignmentFee Decimal? @db.Decimal(12, 2) @map("assignment_fee")

  // Status — acquisition pipeline position (never overwritten by dispo)
  status PropertyStatus @default(NEW_LEAD)
  // Disposition pipeline position — null means not in dispo yet
  dispoStatus PropertyStatus? @map("dispo_status")
  // Moment the current stage was entered — powers days-in-stage badge. Updated on every status/dispoStatus change.
  stageEnteredAt DateTime? @map("stage_entered_at")
  // When true, GHL webhook stage updates skip this property. Used after an
  // auto-split when one property continues in the GHL opp and the other needs
  // to diverge — user manages the locked property's stage manually.
  ghlSyncLocked Boolean @default(false) @map("ghl_sync_locked")

  // Lead tracking
  leadSource       String? @map("lead_source") // GHL opportunity source — tracked for KPIs
  leadSubSource    String? @map("lead_sub_source") // Sub-channel: "Google Ads", "Facebook", "PropertyLeads", etc.

  // TCP — True Conversion Probability (0.0 to 1.0)
  tcpScore     Float?    @map("tcp_score")
  tcpFactors   Json?     @map("tcp_factors") // {callSentiment, touchCount, equity, motivation, ...}
  tcpUpdatedAt DateTime? @map("tcp_updated_at")

  // GHL sync
  ghlContactId     String? @map("ghl_contact_id")
  ghlPipelineId    String? @map("ghl_pipeline_id")
  ghlPipelineStage String? @map("ghl_pipeline_stage")

  // Property details
  beds         Int?
  baths        Int?
  sqft         Int?
  yearBuilt    Int?     @map("year_built")
  lotSize      String?  @map("lot_size")
  propertyType String?  @map("property_type")  // House, Land, Multi-Family, Commercial, Other
  occupancy    String?                          // Vacant, Owner Occupied, Tenant Occupied, Unknown
  projectType  Json     @default("[]") @map("project_type") // ["Flip", "Rental", "Wholesale", etc.]
  lockboxCode  String?  @map("lockbox_code")
  description  String?  @db.Text
  internalNotes String? @db.Text @map("internal_notes")

  // Deal intel (gathered from calls)
  propertyCondition     String?  @map("property_condition")     // Move-in, minor repairs, major rehab, teardown
  competingOfferCount   Int?     @map("competing_offer_count")
  dealHealthScore       Int?     @map("deal_health_score")      // 1-10 composite from AI
  // Full deal intelligence JSON — accumulated from all calls
  dealIntel             Json?    @map("deal_intel") // See lib/types/deal-intel.ts for structure

  // Extended financials
  offerPrice     Decimal? @db.Decimal(12, 2) @map("offer_price")
  repairCost     Decimal? @db.Decimal(12, 2) @map("repair_cost")
  wholesalePrice Decimal? @db.Decimal(12, 2) @map("wholesale_price")
  currentOffer   Decimal? @db.Decimal(12, 2) @map("current_offer")
  highestOffer   Decimal? @db.Decimal(12, 2) @map("highest_offer")
  acceptedPrice  Decimal? @db.Decimal(12, 2) @map("accepted_price")
  finalProfit    Decimal? @db.Decimal(12, 2) @map("final_profit")

  // Source tracking for AI vs user edits — { fieldName: "ai" | "user" }
  fieldSources   Json     @default("{}") @map("field_sources")

  // Tracking dates
  lastOfferDate      DateTime? @map("last_offer_date")
  lastContactedDate  DateTime? @map("last_contacted_date")

  // Market assignment
  marketId String? @map("market_id")
  market   Market? @relation(fields: [marketId], references: [id])
  propertyMarkets  Json @default("[]") @map("property_markets") // ["Nashville", "Hot Springs", "Arkansas"]
  manualBuyerIds   Json @default("[]") @map("manual_buyer_ids") // GHL contact IDs added manually for this property

  // Enrichment (Phase 2 — Zillow, county records)
  zillowData   Json? @map("zillow_data")
  countyData   Json? @map("county_data")
  constructionEstimate Decimal? @db.Decimal(12, 2) @map("construction_estimate")

  // Utilities
  waterType       String? @map("water_type")
  waterNotes      String? @map("water_notes")
  sewerType       String? @map("sewer_type")
  sewerCondition  String? @map("sewer_condition")
  sewerNotes      String? @map("sewer_notes")
  electricType    String? @map("electric_type")
  electricNotes   String? @map("electric_notes")

  // AI enrichment (Fix 4)
  repairEstimate      Decimal? @db.Decimal(12, 2) @map("repair_estimate")
  rentalEstimate      Decimal? @db.Decimal(12, 2) @map("rental_estimate")
  neighborhoodSummary String?  @map("neighborhood_summary") @db.Text
  zestimate           Decimal? @db.Decimal(12, 2)
  deedDate            DateTime? @map("deed_date")
  taxAssessment       Decimal? @db.Decimal(12, 2) @map("tax_assessment")
  annualTax           Decimal? @db.Decimal(12, 2) @map("annual_tax")
  floodZone           String?  @map("flood_zone")
  aiEnrichmentStatus  String?  @map("ai_enrichment_status") // 'pending' | 'complete' | 'failed'
  aiEnrichmentError   String?  @map("ai_enrichment_error")

  // Deal Blast overrides (Fix 5) — wholesalers show different numbers to buyers
  dealBlastAskingOverride        Decimal? @db.Decimal(12, 2) @map("deal_blast_asking_override")
  dealBlastArvOverride           Decimal? @db.Decimal(12, 2) @map("deal_blast_arv_override")
  dealBlastContractOverride      Decimal? @db.Decimal(12, 2) @map("deal_blast_contract_override")
  dealBlastAssignmentFeeOverride Decimal? @db.Decimal(12, 2) @map("deal_blast_assignment_fee_override")

  // Alt offer types (Novation, Subto, Partnership, etc.) — Cash lives in top-level
  // askingPrice/mao/contractPrice/etc. columns; altPrices holds per-type overrides
  // keyed by offer type. Shape: { novation: { mao: "180000", askingPrice: "240000", ... }, ... }
  offerTypes Json @default("[]") @map("offer_types")   // String[] — ["Novation", "Subto", "Partnership"]
  altPrices  Json @default("{}") @map("alt_prices")

  // Property Story — AI-generated narrative, refreshed on call.graded + daily cron
  story           String?   @db.Text
  storyUpdatedAt  DateTime? @map("story_updated_at")
  storyVersion    Int       @default(0) @map("story_version")

  // Risk factor — free-form per-deal risk label (e.g. "High", "8/10", "title issue").
  // Per-offer-type values live in altPrices[type].riskFactor; this column is the Cash value.
  riskFactor      String?   @map("risk_factor")

  // Exterior / structural condition grades. Free-form strings so users can
  // pick any scheme (A-F, 1-10, "Good", "Needs replacement"); kept intentionally
  // loose until a grading standard emerges.
  roofCondition      String? @map("roof_condition")
  windowsCondition   String? @map("windows_condition")
  sidingCondition    String? @map("siding_condition")
  exteriorCondition  String? @map("exterior_condition")

  // Intangibles — qualitative, subjective grades that require eyes-on or
  // neighborhood feel and don't come from any data API.
  comparableRisk     String? @map("comparable_risk")
  basementStatus     String? @map("basement_status")
  curbAppeal         String? @map("curb_appeal")
  neighborsGrade     String? @map("neighbors_grade")
  parkingType        String? @map("parking_type")
  yardGrade          String? @map("yard_grade")

  // Location + market-level grades — typically applied once per deal after
  // driving the area / pulling comps, not per-offer-type.
  locationGrade      String? @map("location_grade")
  marketRisk         String? @map("market_risk")

  // ── Vendor enrichment (Tier 1+2) ──
  // Promoted from zillowData.batchData JSON blob so we can query/filter
  // without JSON introspection and accept the same shape from PropertyRadar,
  // RealEstateAPI, RentCast as they wire up. All optional — enrichment is
  // opportunistic, vendors overlap.

  // Identity & location
  county                  String?
  latitude                Decimal? @db.Decimal(10, 8)
  longitude               Decimal? @db.Decimal(11, 8)
  apn                     String?
  fips                    String?
  subdivision             String?

  // Owner
  absenteeOwner           Boolean? @map("absentee_owner")
  ownerPhone              String?  @map("owner_phone")
  ownerEmail              String?  @map("owner_email")
  ownerType               String?  @map("owner_type")
  ownershipLengthYears    Int?     @map("ownership_length_years")
  secondOwnerName         String?  @map("second_owner_name")
  secondOwnerPhone        String?  @map("second_owner_phone")
  secondOwnerEmail        String?  @map("second_owner_email")

  // Primary mortgage
  mortgageAmount          Decimal? @db.Decimal(12, 2) @map("mortgage_amount")
  mortgageDate            DateTime? @map("mortgage_date")
  mortgageLender          String?  @map("mortgage_lender")
  mortgageType            String?  @map("mortgage_type")
  mortgageRate            Decimal? @db.Decimal(5, 3) @map("mortgage_rate")

  // Second mortgage / HELOC
  secondMortgageAmount    Decimal? @db.Decimal(12, 2) @map("second_mortgage_amount")
  secondMortgageDate      DateTime? @map("second_mortgage_date")
  secondMortgageLender    String?  @map("second_mortgage_lender")

  // Liens & legal
  lienCount               Int?     @map("lien_count")
  propertyLienAmount      Decimal? @db.Decimal(12, 2) @map("property_lien_amount")
  lienTypes               Json     @default("[]") @map("lien_types")
  judgmentCount           Int?     @map("judgment_count")

  // Distress & foreclosure
  taxDelinquent           Boolean? @map("tax_delinquent")
  taxDelinquentAmount     Decimal? @db.Decimal(12, 2) @map("tax_delinquent_amount")
  foreclosureStatus       String?  @map("foreclosure_status")
  bankOwned               Boolean? @map("bank_owned")
  preForeclosure          Boolean? @map("pre_foreclosure")
  nodDate                 DateTime? @map("nod_date")
  lisPendensDate          DateTime? @map("lis_pendens_date")
  lisPendensAmount        Decimal? @db.Decimal(12, 2) @map("lis_pendens_amount")
  lisPendensPlaintiff     String?  @map("lis_pendens_plaintiff")
  foreclosureAuctionDate  DateTime? @map("foreclosure_auction_date")
  foreclosureOpeningBid   Decimal? @db.Decimal(12, 2) @map("foreclosure_opening_bid")

  // Structure
  stories                 Int?
  units                   Int?
  basementFinishedPercent Int?     @map("basement_finished_percent")

  // Transfer / deed history
  lastSalePrice           Decimal? @db.Decimal(12, 2) @map("last_sale_price")
  transferCount           Int?     @map("transfer_count")
  deedType                String?  @map("deed_type")
  dataLastUpdated         DateTime? @map("data_last_updated")

  // Construction detail (Tier 2)
  roofType                String?  @map("roof_type")
  foundationType          String?  @map("foundation_type")
  garageType              String?  @map("garage_type")
  garageCapacity          Int?     @map("garage_capacity")
  heatingSystem           String?  @map("heating_system")
  coolingSystem           String?  @map("cooling_system")
  exteriorWalls           String?  @map("exterior_walls")

  // Amenity flags (Tier 2)
  hasPool                 Boolean? @map("has_pool")
  hasDeck                 Boolean? @map("has_deck")
  hasPorch                Boolean? @map("has_porch")
  hasSolar                Boolean? @map("has_solar")
  hasFireplace            Boolean? @map("has_fireplace")
  hasSpa                  Boolean? @map("has_spa")

  // Zoning / neighborhood
  zoningCode              String?  @map("zoning_code")
  landUseCode             String?  @map("land_use_code")
  propertySchoolDistrict  String?  @map("property_school_district")

  // Environmental risk (floodZone already exists above)
  earthquakeZone          String?  @map("earthquake_zone")
  wildfireRisk            String?  @map("wildfire_risk")

  // Vacancy signals (BatchData ships 4 orthogonal flags)
  vacantStatus            String?  @map("vacant_status")
  vacantStatusYear        Int?     @map("vacant_status_year")
  siteVacant              Boolean? @map("site_vacant")
  mailVacant              Boolean? @map("mail_vacant")

  // ── Vendor enrichment (Tier 3) ──
  // Vendor-exclusive signals confirmed 2026-04-23: PropertyRadar's distress
  // composite + legal flags, REAPI's MLS activity + HUD demographics +
  // school detail. All returned on calls we already pay for — promoted to
  // typed columns so the inventory UI can filter on them directly.

  // PropertyRadar distress composite + legal distress flags
  distressScore           Int?     @map("distress_score")
  inBankruptcy            Boolean? @map("in_bankruptcy")
  inProbate               Boolean? @map("in_probate")
  inDivorce               Boolean? @map("in_divorce")
  hasRecentEviction       Boolean? @map("has_recent_eviction")
  isRecentFlip            Boolean? @map("is_recent_flip")
  isRecentSale            Boolean? @map("is_recent_sale")
  isListedForSale         Boolean? @map("is_listed_for_sale")
  isAuction               Boolean? @map("is_auction")

  // Equity detail (beyond the equity_percent kept in fieldSources)
  availableEquity         Decimal? @db.Decimal(12, 2) @map("available_equity")
  estimatedEquity         Decimal? @db.Decimal(12, 2) @map("estimated_equity")
  equityPercent           Decimal? @db.Decimal(5, 2)  @map("equity_percent")
  openMortgageBalance     Decimal? @db.Decimal(12, 2) @map("open_mortgage_balance")
  estimatedMortgagePayment Decimal? @db.Decimal(12, 2) @map("estimated_mortgage_payment")

  // Inheritance / death transfer + mortgage assumability (REAPI)
  inherited               Boolean?
  deathTransfer           Boolean? @map("death_transfer")
  mortgageAssumable       Boolean? @map("mortgage_assumable")

  // MLS activity (REAPI)
  mlsActive               Boolean? @map("mls_active")
  mlsPending              Boolean? @map("mls_pending")
  mlsSold                 Boolean? @map("mls_sold")
  mlsCancelled            Boolean? @map("mls_cancelled")
  mlsFailed               Boolean? @map("mls_failed")
  mlsStatus               String?  @map("mls_status")
  mlsType                 String?  @map("mls_type")
  mlsListingDate          DateTime? @map("mls_listing_date")
  mlsListingPrice         Decimal? @db.Decimal(12, 2) @map("mls_listing_price")
  mlsSoldPrice            Decimal? @db.Decimal(12, 2) @map("mls_sold_price")
  mlsDaysOnMarket         Int?     @map("mls_days_on_market")
  mlsPricePerSqft         Decimal? @db.Decimal(10, 2) @map("mls_price_per_sqft")
  mlsKeywords             Json     @default("[]") @map("mls_keywords")
  mlsLastStatusDate       DateTime? @map("mls_last_status_date")

  // Flood detail
  floodZoneType           String?  @map("flood_zone_type")

  // REAPI demographics / HUD area data
  suggestedRent           Decimal? @db.Decimal(10, 2) @map("suggested_rent")
  medianIncome            Decimal? @db.Decimal(12, 2) @map("median_income")
  hudAreaCode             String?  @map("hud_area_code")
  hudAreaName             String?  @map("hud_area_name")
  fmrYear                 Int?     @map("fmr_year")
  fmrEfficiency           Decimal? @db.Decimal(10, 2) @map("fmr_efficiency")
  fmrOneBedroom           Decimal? @db.Decimal(10, 2) @map("fmr_one_bedroom")
  fmrTwoBedroom           Decimal? @db.Decimal(10, 2) @map("fmr_two_bedroom")
  fmrThreeBedroom         Decimal? @db.Decimal(10, 2) @map("fmr_three_bedroom")
  fmrFourBedroom          Decimal? @db.Decimal(10, 2) @map("fmr_four_bedroom")

  // Schools (REAPI returns an array; promote primary + keep full list in JSON)
  schoolPrimaryName       String?  @map("school_primary_name")
  schoolPrimaryRating     Int?     @map("school_primary_rating")
  schoolsJson             Json     @default("[]") @map("schools_json")

  // ── PropertyRadar subscription extras ──
  // Structured name parts (CourtListener + skip-trace both want these)
  ownerFirstName1         String?  @map("owner_first_name_1")
  ownerLastName1          String?  @map("owner_last_name_1")
  ownerFirstName2         String?  @map("owner_first_name_2")
  ownerLastName2          String?  @map("owner_last_name_2")
  pctChangeInValue        Decimal? @db.Decimal(6, 2)  @map("pct_change_in_value")
  cashSale                Boolean? @map("cash_sale")
  investorType            String?  @map("investor_type")
  hoaDues                 Decimal? @db.Decimal(10, 2) @map("hoa_dues")
  hoaPastDue              Boolean? @map("hoa_past_due")
  hoaName                 String?  @map("hoa_name")
  lastMlsStatus           String?  @map("last_mls_status")
  lastMlsListPrice        Decimal? @db.Decimal(12, 2) @map("last_mls_list_price")
  lastMlsSoldPrice        Decimal? @db.Decimal(12, 2) @map("last_mls_sold_price")
  // Q3 lock (v1.1 Wave 1) — renamed from ownerMailingVacant. About a property
  // (the owner's MAILING property, not THIS property) — kept on Property side
  // since it's a property fact, not a person fact.
  mailingAddressVacant    Boolean? @map("mailing_address_vacant")

  // ── PropertyRadar detail fields (condition + census + tax rate) ──
  improvementCondition    String?  @map("improvement_condition")
  buildingQuality         String?  @map("building_quality")
  estimatedTaxRate        Decimal? @db.Decimal(5, 2) @map("estimated_tax_rate")
  censusTract             String?  @map("census_tract")
  censusBlock             String?  @map("census_block")
  carrierRoute            String?  @map("carrier_route")
  legalDescription        String?  @map("legal_description")

  // ── Comprehensive vendor capture (migration 20260423060000) ─────
  // Address metadata (BatchData USPS validation)
  addressValidity         String?  @map("address_validity")
  zipPlus4                String?  @map("zip_plus4")

  // BatchData intel (seller motivation)
