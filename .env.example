# Gunner — Environment Variables
# Copy this to .env and fill in values for local development
# All production values live in Railway dashboard

# Database
DATABASE_URL=postgresql://gunner:password@localhost:5432/gunner

# Auth
JWT_SECRET=your-jwt-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI
OPENAI_API_KEY=sk-proj-...

# Storage (Supabase)
SUPABASE_SERVICE_KEY=sb_secret_...

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@getgunner.ai
LOOPS_API_KEY=...

# Payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CRM
GHL_CLIENT_ID=...
GHL_CLIENT_SECRET=...

# Fraud protection
TURNSTILE_SECRET_KEY=...

# Observability
SENTRY_DSN=...
POSTHOG_API_KEY=...
LANGSMITH_API_KEY=...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=gunner

# Frontend (build-time)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_TURNSTILE_SITE_KEY=...

# Platform
OWNER_OPEN_ID=google_...
NODE_ENV=development
