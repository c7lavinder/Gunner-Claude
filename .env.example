# Gunner — Environment Variables
# Copy this to .env and fill in values for local development
# All production values live in Railway dashboard

# Database
DATABASE_URL=postgresql://gunner:password@localhost:5432/gunner

# Auth
JWT_SECRET=your-jwt-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI
OPENAI_API_KEY=sk-proj-...

# Storage (Supabase) — REQUIRED — server won't start without these
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@getgunner.ai
# TODO: implement Loops drip sequences before enabling
LOOPS_API_KEY=...

# Payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CRM
GHL_CLIENT_ID=...
GHL_CLIENT_SECRET=...
GHL_WEBHOOK_SECRET=...

# Fraud protection
TURNSTILE_SECRET_KEY=...

# Observability
SENTRY_DSN=...
POSTHOG_API_KEY=...
# TODO: LANGCHAIN_API_KEY has no effect until llm.ts switches to @langchain/openai SDK
LANGCHAIN_API_KEY=...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=gunner

# Frontend (build-time Vite vars — must ALSO be set in Railway as env vars)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_TURNSTILE_SITE_KEY=...
VITE_SENTRY_DSN=...
# PostHog frontend analytics — set this in Railway separately from POSTHOG_API_KEY
VITE_POSTHOG_API_KEY=phc_...
VITE_APP_TITLE=Gunner

# Platform
OWNER_OPEN_ID=google_...
NODE_ENV=development
