# Gunner AI — Environment Variables
# Copy this to .env.local for development
# Add all of these to Railway for production

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-min-32-chars-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://gunner-claude-production.up.railway.app
# For local dev: NEXTAUTH_URL=http://localhost:3000

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get both from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── GHL Marketplace App ─────────────────────────────────────────────────────
# Get from: GHL → Settings → Developer → Apps → Your App
GHL_CLIENT_ID=your-ghl-client-id
GHL_CLIENT_SECRET=your-ghl-client-secret
GHL_REDIRECT_URI=https://gunner-claude-production.up.railway.app/api/auth/crm/callback
GHL_WEBHOOK_SECRET=your-webhook-secret-generate-randomly
NEXT_PUBLIC_GHL_CLIENT_ID=your-ghl-client-id

# ─── AI — Anthropic (required) ───────────────────────────────────────────────
# Powers call grading, coaching, assistant, deal intel extraction
ANTHROPIC_API_KEY=sk-ant-your-api-key

# ─── AI — OpenAI (optional) ──────────────────────────────────────────────────
# Enables pgvector semantic search for playbook knowledge
# Without this, knowledge lookup uses exact type/role matching (still works)
OPENAI_API_KEY=sk-your-openai-key

# ─── Deepgram (call transcription) ───────────────────────────────────────────
# Get from: deepgram.com → API Keys
# Without this, calls are graded on metadata only (no transcript)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Without this, invite emails logged to console but not sent
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Gunner AI <noreply@yourdomain.com>

# ─── Stripe (optional — activate when ready for billing) ─────────────────────
# Get from: stripe.com → Developers → API Keys
# STRIPE_SECRET_KEY=sk_live_your_key
# STRIPE_WEBHOOK_SECRET=whsec_your_key
# STRIPE_PRICE_STARTER=price_xxx (monthly $97)
# STRIPE_PRICE_GROWTH=price_xxx (monthly $197)
# STRIPE_PRICE_TEAM=price_xxx (monthly $397)

# ─── BatchData (property enrichment — optional) ──────────────────────────────
# BATCHDATA_API_KEY=your-batchdata-key

# ─── Cron Security ───────────────────────────────────────────────────────────
# Secret for Railway cron job auth (generate randomly)
CRON_SECRET=generate-a-random-string-here

# ─── Diagnostic Endpoints ────────────────────────────────────────────────────
# Required for /api/diagnostics/* endpoints. When unset, those endpoints
# return 401 to all callers (fail closed). Generate randomly, set on Railway.
# DIAGNOSTIC_TOKEN=generate-a-random-string-here

# ─── Dev Only ─────────────────────────────────────────────────────────────────
# DEV_BYPASS_AUTH=true  # Skip login for local dev (NEVER set on Railway)

# ─── Visual Audit (scripts/visual-audit.ts) ──────────────────────────────────
# When VISUAL_AUDIT_EMAIL is unset the script no-ops, so leave commented in prod.
# VISUAL_AUDIT_EMAIL=qa+visual@yourdomain.com
# VISUAL_AUDIT_PASSWORD=set-the-password-here
# VISUAL_AUDIT_TENANT=new-again-houses          # tenant slug used in URLs (default: new-again-houses)
# VISUAL_AUDIT_BASE_URL=http://localhost:3000   # base URL to screenshot (default: http://localhost:3000)
