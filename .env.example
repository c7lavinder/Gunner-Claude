# ============================================================
# Gunner — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.tvjkgumckwapybpjyrkw.supabase.co:5432/postgres

# Auth
JWT_SECRET=[generate-random-32-char-string]
GOOGLE_CLIENT_ID=822409973740-unk86h5t2ah1n7avlusdnspiicm96rnh.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=[from-google-cloud-console]

# App
APP_URL=https://getgunner.ai
VITE_APP_TITLE=Gunner
NODE_ENV=production

# GoHighLevel (GHL) OAuth App
GHL_CLIENT_ID=[from-ghl-dev-settings]
GHL_CLIENT_SECRET=[from-ghl-dev-settings]

# Stripe
STRIPE_SECRET_KEY=[from-stripe-dashboard]
VITE_STRIPE_PUBLISHABLE_KEY=[from-stripe-dashboard]
STRIPE_WEBHOOK_SECRET=[from-stripe-dashboard]

# BatchDialer
BATCHDIALER_API_KEY=d98ac867-62b7-439d-8d72-a19004a93e25

# BatchLeads
BATCHLEADS_API_KEY=06b81a7c-f69c-42c3-bc1f-c8ed55d01e1a

# Cloudflare Turnstile (bot protection on signup)
VITE_TURNSTILE_SITE_KEY=[from-cloudflare-dashboard]
TURNSTILE_SECRET_KEY=[from-cloudflare-dashboard]

# AWS S3 (for call recording storage and transcripts)
AWS_ACCESS_KEY_ID=[from-aws-iam]
AWS_SECRET_ACCESS_KEY=[from-aws-iam]
AWS_REGION=us-east-1
AWS_S3_BUCKET=[your-bucket-name]

# AI (OpenAI for call grading)
OPENAI_API_KEY=[from-openai-dashboard]

# Resend (transactional email)
RESEND_API_KEY=[from-resend-dashboard]

# ============================================================
# Manus-specific vars — NO LONGER NEEDED after migration
# Leave blank or omit entirely
# ============================================================
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
